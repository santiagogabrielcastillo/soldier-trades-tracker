<div class="<%= wrapper_css %>">
  <div>
    <h1 class="text-2xl font-semibold text-slate-900"><%= @title %></h1>
    <% if @subtitle %>
      <p class="mt-1 text-sm text-slate-500"><%= @subtitle %></p>
    <% end %>
  </div>
  <% if actions %>
    <div class="flex items-center gap-3"><%= actions %></div>
  <% end %>
</div>
