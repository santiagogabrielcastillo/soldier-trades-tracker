<nav class="mb-6" aria-label="Tabs">
  <div class="inline-flex items-center gap-0.5 rounded-xl bg-slate-100 p-1">
    <% @tabs.each do |tab| %>
      <%= link_to tab.url, class: tab_css(tab.active), **(tab.active ? { "aria-current": "page" } : {}) do %>
        <%= tab.label %>
      <% end %>
    <% end %>
  </div>
</nav>
