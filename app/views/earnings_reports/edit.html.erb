<div class="mx-auto max-w-4xl">
  <%= render BreadcrumbComponent.new(items: [
    { label: t("companies.index.title"), url: companies_path },
    { label: @company.ticker, url: company_path(@company) },
    { label: @report.period_label, url: company_earnings_report_path(@company, @report) },
    { label: t("earnings_reports.edit.breadcrumb"), url: nil }
  ]) %>
  <div class="mb-6">
    <h1 class="text-2xl font-semibold text-slate-900"><%= t("earnings_reports.edit.title", period: @report.period_label) %></h1>
  </div>
  <%= render "form" %>
</div>
