<div class="mx-auto max-w-4xl">
  <%= render BreadcrumbComponent.new(items: [
    { label: "Companies", url: companies_path },
    { label: @company.ticker, url: company_path(@company) },
    { label: @report.period_label, url: company_earnings_report_path(@company, @report) },
    { label: "Edit", url: nil }
  ]) %>
  <div class="mb-6">
    <h1 class="text-2xl font-semibold text-slate-900">Edit <%= @report.period_label %></h1>
  </div>
  <%= render "form" %>
</div>
