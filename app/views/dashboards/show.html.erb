<div>
  <h1 class="mb-2 text-2xl font-semibold text-slate-900">Dashboard</h1>
  <p class="mb-6 text-slate-600">Centralize your trade activity across exchanges.</p>

  <section class="mb-8 rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
    <h2 class="mb-4 text-lg font-medium text-slate-900">Period summary</h2>
    <p class="mb-2 text-sm text-slate-600"><%= @dashboard.summary_label %><% if @dashboard.summary_date_range %> · <%= @dashboard.summary_date_range %><% end %></p>
    <div class="mb-4 flex flex-wrap items-baseline gap-6">
      <div>
        <span class="text-sm text-slate-500">Balance</span>
        <p class="text-xl font-semibold text-slate-900"><%= format_money(@dashboard.summary_balance) %></p>
      </div>
      <div>
        <span class="text-sm text-slate-500">Period P&amp;L</span>
        <p class="text-xl font-semibold <%= @dashboard.summary_period_pl >= 0 ? 'text-emerald-600' : 'text-red-600' %>"><%= format_money(@dashboard.summary_period_pl) %></p>
      </div>
      <div>
        <span class="text-sm text-slate-500">Total return</span>
        <p class="text-xl font-semibold <%= @dashboard.summary_total_return_pct.nil? ? 'text-slate-900' : (@dashboard.summary_total_return_pct >= 0 ? 'text-emerald-600' : 'text-red-600') %>"><%= @dashboard.summary_total_return_pct.nil? ? "—" : "#{number_with_precision(@dashboard.summary_total_return_pct, precision: 2)}%" %></p>
      </div>
      <div>
        <span class="text-sm text-slate-500">Unrealized P&amp;L</span>
        <p class="text-xl font-semibold <%= @dashboard.summary_unrealized_pl.nil? ? 'text-slate-900' : (@dashboard.summary_unrealized_pl >= 0 ? 'text-emerald-600' : 'text-red-600') %>"><%= @dashboard.summary_unrealized_pl.nil? ? "—" : format_money(@dashboard.summary_unrealized_pl) %></p>
      </div>
      <div>
        <span class="text-sm text-slate-500">Positions</span>
        <p class="text-xl font-semibold text-slate-900"><%= @dashboard.summary_position_count %></p>
      </div>
    </div>
    <div class="mb-4 flex flex-wrap items-baseline gap-6">
      <span class="text-sm font-medium text-slate-700">Consistency</span>
      <div>
        <span class="text-sm text-slate-500">Win rate</span>
        <p class="text-lg font-semibold text-slate-900"><%= @dashboard.summary_win_rate.nil? ? "—" : "#{number_with_precision(@dashboard.summary_win_rate, precision: 1)}%" %></p>
      </div>
      <div>
        <span class="text-sm text-slate-500">Avg win</span>
        <p class="text-lg font-semibold text-emerald-600"><%= @dashboard.summary_avg_win.nil? ? "—" : format_money(@dashboard.summary_avg_win) %></p>
      </div>
      <div>
        <span class="text-sm text-slate-500">Avg loss</span>
        <p class="text-lg font-semibold text-red-600"><%= @dashboard.summary_avg_loss.nil? ? "—" : format_money(@dashboard.summary_avg_loss) %></p>
      </div>
      <div>
        <span class="text-sm text-slate-500">Closed</span>
        <p class="text-lg font-semibold text-slate-900"><%= @dashboard.summary_closed_count || 0 %></p>
      </div>
    </div>
    <%= link_to "View trades", @dashboard.summary_trades_path, class: "inline-block rounded-md bg-slate-800 px-4 py-2 text-sm font-medium text-white hover:bg-slate-700" %>
    <% if @dashboard.default_portfolio.nil? && current_user.portfolios.any? %>
      <span class="ml-3 text-sm text-slate-500">or <%= link_to "set a default portfolio", portfolios_path, class: "text-slate-700 underline hover:text-slate-900" %></span>
    <% elsif @dashboard.default_portfolio.nil? %>
      <span class="ml-3 text-sm text-slate-500">or <%= link_to "create a portfolio", new_portfolio_path, class: "text-slate-700 underline hover:text-slate-900" %></span>
    <% end %>
  </section>

  <%= content_tag :section, class: "mb-8 rounded-lg border border-slate-200 bg-white p-6 shadow-sm", data: { controller: "dashboard-charts", dashboard_charts_value_value: { balance_series: @dashboard.chart_balance_series, cumulative_pl_series: @dashboard.chart_cumulative_pl_series } } do %>
    <h2 class="mb-4 text-lg font-medium text-slate-900">Performance over time</h2>
    <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
      <div>
        <p class="mb-2 text-sm text-slate-500">Balance</p>
        <div class="h-48" data-dashboard-charts-target="balanceContainer">
          <canvas data-dashboard-charts-target="balanceCanvas"></canvas>
          <p class="hidden text-sm text-slate-500" data-dashboard-charts-target="balanceEmpty">No closed positions yet.</p>
        </div>
      </div>
      <div>
        <p class="mb-2 text-sm text-slate-500">Cumulative P&amp;L</p>
        <div class="h-48" data-dashboard-charts-target="plContainer">
          <canvas data-dashboard-charts-target="plCanvas"></canvas>
          <p class="hidden text-sm text-slate-500" data-dashboard-charts-target="plEmpty">No closed positions yet.</p>
        </div>
      </div>
    </div>
  <% end %>

  <%= content_tag :section, class: "mb-8 rounded-lg border border-slate-200 bg-white p-6 shadow-sm", data: { controller: "spot-chart", spot_chart_series_value: (@dashboard.spot_chart_series || []) } do %>
    <h2 class="mb-4 text-lg font-medium text-slate-900">Spot</h2>
    <div class="mb-4 flex flex-wrap items-baseline gap-6">
      <div>
        <span class="text-sm text-slate-500">Total value</span>
        <p class="text-xl font-semibold text-slate-900"><%= format_money(@dashboard.spot_value) %></p>
      </div>
      <div>
        <span class="text-sm text-slate-500">Cost basis</span>
        <p class="text-xl font-semibold text-slate-900"><%= format_money(@dashboard.spot_cost_basis) %></p>
      </div>
      <div>
        <span class="text-sm text-slate-500">Unrealized P&amp;L</span>
        <p class="text-xl font-semibold <%= (@dashboard.spot_unrealized_pl || 0).to_d >= 0 ? 'text-emerald-600' : 'text-red-600' %>"><%= format_money(@dashboard.spot_unrealized_pl) %></p>
      </div>
      <div>
        <span class="text-sm text-slate-500">Unrealized ROI</span>
        <p class="text-xl font-semibold <%= @dashboard.spot_roi_pct.nil? ? 'text-slate-900' : (@dashboard.spot_roi_pct >= 0 ? 'text-emerald-600' : 'text-red-600') %>"><%= @dashboard.spot_roi_pct.nil? ? "—" : "#{number_with_precision(@dashboard.spot_roi_pct, precision: 2)}%" %></p>
      </div>
      <div>
        <span class="text-sm text-slate-500">Open positions</span>
        <p class="text-xl font-semibold text-slate-900"><%= @dashboard.spot_position_count || 0 %></p>
      </div>
      <div>
        <span class="text-sm text-slate-500">Cash balance</span>
        <p class="text-xl font-semibold <%= (@dashboard.spot_cash_balance || 0).to_d >= 0 ? 'text-slate-900' : 'text-red-600' %>"><%= format_money(@dashboard.spot_cash_balance || 0) %></p>
      </div>
      <div>
        <span class="text-sm text-slate-500">Cash % of portfolio</span>
        <p class="text-xl font-semibold text-slate-900"><%= @dashboard.spot_cash_pct.nil? ? "—" : "#{number_with_precision(@dashboard.spot_cash_pct, precision: 2)}%" %></p>
      </div>
    </div>
    <div class="mb-4">
      <p class="mb-2 text-sm text-slate-500">Cost basis over time</p>
      <div class="h-40">
        <canvas data-spot-chart-target="canvas"></canvas>
        <p class="hidden text-sm text-slate-500" data-spot-chart-target="empty">No spot transactions yet.</p>
      </div>
    </div>
    <%= link_to "View spot portfolio", spot_path, class: "inline-block rounded-md bg-slate-800 px-4 py-2 text-sm font-medium text-white hover:bg-slate-700" %>
  <% end %>

  <section class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
    <h2 class="mb-4 text-lg font-medium text-slate-900">Exchange accounts</h2>
    <% if @dashboard.exchange_accounts.any? %>
      <ul class="space-y-3">
        <% @dashboard.exchange_accounts.each do |account| %>
          <li class="flex items-center justify-between rounded-md border border-slate-100 py-2 px-3">
            <span class="font-medium capitalize"><%= account.provider_type %></span>
            <span class="text-sm text-slate-500">Linked <%= time_ago_in_words(account.linked_at || account.created_at) %> ago</span>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-slate-600">No exchange accounts linked yet.</p>
    <% end %>
    <%= link_to "Link exchange account", new_exchange_account_path, class: "mt-4 inline-block rounded-md bg-slate-800 px-4 py-2 text-sm font-medium text-white hover:bg-slate-700" %>
    <%= link_to "Manage portfolios", portfolios_path, class: "mt-4 ml-3 inline-block text-sm text-slate-600 hover:text-slate-900" %>
  </section>
</div>
