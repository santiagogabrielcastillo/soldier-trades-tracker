<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Soldier Trades Tracker" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-slate-50 text-slate-900">
    <header class="border-b border-slate-200 bg-white">
      <nav class="container mx-auto flex h-14 items-center justify-between px-4">
        <%= link_to "Soldier Trades", root_path, class: "text-lg font-semibold text-slate-800" %>
        <div class="flex items-center gap-4">
          <% if current_user %>
            <%= link_to "Dashboard", root_path, class: "text-sm text-slate-600 hover:text-slate-900" %>
            <%= link_to "Exchange accounts", exchange_accounts_path, class: "text-sm text-slate-600 hover:text-slate-900" %>
            <%= link_to "Trades", trades_path, class: "text-sm text-slate-600 hover:text-slate-900" %>
            <%= link_to "Portfolios", portfolios_path, class: "text-sm text-slate-600 hover:text-slate-900" %>
            <%= link_to "Settings", settings_path, class: "text-sm text-slate-600 hover:text-slate-900" %>
            <%= button_to "Sign out", logout_path, method: :delete, class: "text-sm text-slate-600 hover:text-slate-900" %>
          <% else %>
            <%= link_to "Sign in", login_path, class: "text-sm text-slate-600 hover:text-slate-900" %>
            <%= link_to "Sign up", new_user_path, class: "rounded-md bg-slate-800 px-3 py-2 text-sm font-medium text-white hover:bg-slate-700" %>
          <% end %>
        </div>
      </nav>
    </header>
    <% if flash[:notice] %>
      <p class="container mx-auto mt-4 px-4 text-sm text-emerald-600"><%= flash[:notice] %></p>
    <% end %>
    <% if flash[:alert] %>
      <p class="container mx-auto mt-4 px-4 text-sm text-amber-600"><%= flash[:alert] %></p>
    <% end %>
    <main class="container mx-auto max-w-6xl px-4 py-8">
      <%= yield %>
    </main>
  </body>
</html>
