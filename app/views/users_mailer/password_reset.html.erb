<div style="font-family: sans-serif; max-width: 480px; margin: 0 auto; color: #1e293b;">
  <h2 style="font-size: 18px; font-weight: 600; margin-bottom: 8px;"><%= t("mailers.users_mailer.password_reset.heading") %></h2>
  <p style="font-size: 14px; color: #475569; margin-bottom: 24px;">
    <%= t("mailers.users_mailer.password_reset.body", email: @user.email) %>
  </p>
  <a href="<%= @reset_url %>"
     style="display: inline-block; background-color: #4f46e5; color: #ffffff; font-size: 14px;
            font-weight: 500; padding: 10px 20px; border-radius: 6px; text-decoration: none;">
    <%= t("mailers.users_mailer.password_reset.button") %>
  </a>
  <p style="font-size: 13px; color: #94a3b8; margin-top: 24px;">
    <%= t("mailers.users_mailer.password_reset.ignore") %>
  </p>
  <p style="font-size: 12px; color: #cbd5e1; margin-top: 8px; word-break: break-all;">
    <%= t("mailers.users_mailer.password_reset.copy_link") %> <%= @reset_url %>
  </p>
</div>
