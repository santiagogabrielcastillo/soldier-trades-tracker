<%= form_with model: @portfolio, local: true, class: "space-y-4", data: { turbo: false } do |f| %>
  <%= render ErrorSummaryComponent.new(model: @portfolio) %>

  <%= render FormFieldComponent.new(form: f, attribute: :name, label: t("portfolios.form.name"), placeholder: "e.g. March 2026") %>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :start_date, t("portfolios.form.start_date"), class: "block text-sm font-medium text-slate-700" %>
      <%= f.date_field :start_date, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
    </div>
    <div>
      <%= f.label :end_date, t("portfolios.form.end_date"), class: "block text-sm font-medium text-slate-700" %>
      <%= f.date_field :end_date, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
    </div>
  </div>

  <div>
    <%= f.label :exchange_account_id, t("portfolios.form.include_trades_from"), class: "block text-sm font-medium text-slate-700" %>
    <%= f.select :exchange_account_id, options_for_select([[t("portfolios.form.all_exchanges"), nil]] + current_user.exchange_accounts.map { |a| [a.provider_type.to_s.capitalize, a.id] }, @portfolio.exchange_account_id), {}, { class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" } %>
    <p class="mt-1 text-xs text-slate-500"><%= t("portfolios.form.exchange_hint") %></p>
  </div>

  <div>
    <%= f.label :initial_balance, t("portfolios.form.initial_balance"), class: "block text-sm font-medium text-slate-700" %>
    <%= f.number_field :initial_balance, step: 0.01, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500", placeholder: "0" %>
    <p class="mt-1 text-xs text-slate-500"><%= t("portfolios.form.initial_balance_hint") %></p>
  </div>

  <div>
    <%= f.label :notes, t("portfolios.form.notes"), class: "block text-sm font-medium text-slate-700" %>
    <%= f.text_area :notes, rows: 2, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500", placeholder: "e.g. Q1 2026 – LINK focus" %>
  </div>

  <div class="flex items-center">
    <%= f.check_box :default, class: "h-4 w-4 rounded border-slate-300 text-slate-800 focus:ring-slate-500" %>
    <%= f.label :default, t("portfolios.form.set_as_default"), class: "ml-2 block text-sm text-slate-700" %>
  </div>

  <div class="flex gap-3 pt-2">
    <%= f.submit class: "rounded-md bg-slate-800 px-4 py-2 text-sm font-medium text-white hover:bg-slate-700 focus:outline-none focus:ring-2 focus:ring-slate-500 focus:ring-offset-2" %>
    <%= link_to t("portfolios.form.cancel"), portfolios_path, class: "rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50" %>
  </div>
<% end %>
