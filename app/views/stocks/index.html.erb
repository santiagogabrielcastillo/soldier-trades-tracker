<div>
  <div class="mb-4 flex flex-wrap items-start justify-between gap-3">
    <h1 class="text-2xl font-semibold text-slate-900">Stock portfolio</h1>
    <div class="flex items-center gap-3">
      <% if @all_portfolios.size > 1 %>
        <div class="flex items-center gap-2">
          <%= label_tag :portfolio_id, "Portfolio:", class: "text-sm text-slate-600" %>
          <%= select_tag :portfolio_id,
                options_for_select(@all_portfolios.map { |p| [p.name, p.id] }, @stock_portfolio.id),
                onchange: "window.location.href='<%= stocks_path %>?portfolio_id=' + this.value",
                class: "rounded-md border border-slate-300 px-3 py-1.5 text-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
        </div>
      <% end %>
      <%= render ButtonComponent.new(label: "Manage portfolios", href: stock_portfolios_path) %>
    </div>
  </div>

  <% if @stock_portfolio.argentina? %>
    <div class="mb-4 flex flex-wrap items-center gap-3">
      <% if @mep_rate %>
        <span class="inline-flex items-center rounded-full bg-blue-50 px-3 py-1 text-xs font-medium text-blue-700 ring-1 ring-inset ring-blue-600/20">
          MEP: <%= format_ars(@mep_rate) %> ARS/USD
        </span>
      <% else %>
        <span class="inline-flex items-center rounded-full bg-amber-50 px-3 py-1 text-xs font-medium text-amber-700 ring-1 ring-inset ring-amber-600/20">
          MEP rate unavailable — USD estimates hidden
        </span>
      <% end %>
      <%= link_to "Manage CEDEAR instruments", cedear_instruments_path, class: "text-sm text-slate-500 hover:text-slate-800" %>
    </div>
  <% end %>

  <%= render TabNavComponent.new(tabs: [
    { label: "Portfolio", url: stocks_path(stocks_index_filter_params.merge("view" => "portfolio", "portfolio_id" => @stock_portfolio.id)), active: @view == "portfolio" },
    { label: "Transactions", url: stocks_path(stocks_index_filter_params.merge("view" => "transactions", "portfolio_id" => @stock_portfolio.id)), active: @view == "transactions" }
  ]) %>

  <% if @view == "portfolio" %>
  <div class="mb-6 flex flex-wrap items-center gap-3">
    <%= render ModalComponent.new(title: "New trade", trigger_label: "New trade", open_on_connect: @open_new_trade_modal.present?) do %>
      <%= form_with url: stocks_trades_path, method: :post, local: true, data: { turbo: false, controller: @stock_portfolio.argentina? ? "cedear-ratio" : nil, "cedear-ratio-lookup-url-value": cedear_instruments_lookup_path } do |f| %>
        <%= hidden_field_tag :portfolio_id, @stock_portfolio.id %>
        <div class="space-y-4">
          <div>
            <%= f.label :side, "Side", class: "block text-sm font-medium text-slate-700" %>
            <%= f.select :side, options_for_select([["Buy", "buy"], ["Sell", "sell"]], @stock_trade&.side), { include_blank: "Select" }, class: "w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
            <% if @stock_trade&.errors&.key?(:side) %>
              <p class="mt-1 text-sm text-red-600"><%= @stock_trade.errors[:side].first %></p>
            <% end %>
          </div>
          <div>
            <%= f.label :ticker, @stock_portfolio.argentina? ? "CEDEAR ticker" : "Ticker", class: "block text-sm font-medium text-slate-700" %>
            <%= f.text_field :ticker, value: @stock_trade&.ticker, placeholder: "e.g. AAPL", autocomplete: "off",
                  data: @stock_portfolio.argentina? ? { "cedear-ratio-target": "ticker", action: "blur->cedear-ratio#tickerChanged" } : {},
                  class: "w-full rounded-md border border-slate-300 px-3 py-2 text-sm uppercase focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
            <% if @stock_trade&.errors&.key?(:ticker) %>
              <p class="mt-1 text-sm text-red-600"><%= @stock_trade.errors[:ticker].first %></p>
            <% end %>
          </div>
          <div>
            <%= f.label :shares, @stock_portfolio.argentina? ? "CEDEAR units" : "Shares", class: "block text-sm font-medium text-slate-700" %>
            <%= f.number_field :shares, value: @stock_trade&.shares, step: :any, min: 0, placeholder: "0", class: "w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
            <% if @stock_trade&.errors&.key?(:shares) %>
              <p class="mt-1 text-sm text-red-600"><%= @stock_trade.errors[:shares].first %></p>
            <% end %>
          </div>
          <div>
            <%= f.label :price_usd, @stock_portfolio.argentina? ? "Price (ARS)" : "Price (USD)", class: "block text-sm font-medium text-slate-700" %>
            <%= f.number_field :price_usd, value: @stock_trade&.price_usd, step: :any, min: 0, placeholder: "0.00", class: "w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
            <% if @stock_trade&.errors&.key?(:price_usd) %>
              <p class="mt-1 text-sm text-red-600"><%= @stock_trade.errors[:price_usd].first %></p>
            <% end %>
          </div>
          <% if @stock_portfolio.argentina? %>
          <div>
            <label class="block text-sm font-medium text-slate-700">CEDEAR ratio <span class="font-normal text-slate-500">(auto-filled)</span></label>
            <input type="number" step="any" min="0" placeholder="e.g. 10"
                   data-cedear-ratio-target="ratio"
                   class="w-full rounded-md border border-slate-300 bg-slate-50 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500"
                   disabled>
            <p class="mt-1 text-xs text-slate-500">Fetched from your CEDEAR instruments list. For reference only — stored at trade time.</p>
          </div>
          <% end %>
          <div>
            <%= f.label :executed_at, "Date & time", class: "block text-sm font-medium text-slate-700" %>
            <%= f.datetime_local_field :executed_at, value: @stock_trade&.executed_at&.strftime("%Y-%m-%dT%H:%M"), class: "w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
            <p class="mt-1 text-xs text-slate-500">Interpreted in <%= Time.zone.name %> and stored in UTC.</p>
            <% if @stock_trade&.errors&.key?(:executed_at) %>
              <p class="mt-1 text-sm text-red-600"><%= @stock_trade.errors[:executed_at].first %></p>
            <% end %>
          </div>
        </div>
        <div class="mt-6 flex gap-2">
          <%= f.submit "Add trade", class: "rounded-md bg-slate-800 px-4 py-2 text-sm font-medium text-white hover:bg-slate-700 focus:outline-none focus:ring-2 focus:ring-slate-500" %>
          <button type="button" data-action="dialog#close" class="rounded-md border border-slate-300 bg-white px-4 py-2 text-sm text-slate-700 hover:bg-slate-50">Cancel</button>
        </div>
      <% end %>
    <% end %>
  </div>

  <% if @positions.any? %>
    <% price_label = @stock_portfolio.argentina? ? "Price (ARS)" : "Current price" %>
    <% cost_label = @stock_portfolio.argentina? ? "Avg cost (ARS)" : "Avg cost" %>
    <% value_label = @stock_portfolio.argentina? ? "Market value (ARS)" : "Market value" %>
    <% pl_label = @stock_portfolio.argentina? ? "Unrealized P&L (ARS)" : "Unrealized P&L" %>
    <%= render DataTableComponent.new(columns: [
      { label: "Ticker", classes: "text-left" },
      { label: cost_label, classes: "text-right" },
      { label: @stock_portfolio.argentina? ? "CEDEAR units" : "Shares", classes: "text-right" },
      { label: price_label, classes: "text-right" },
      { label: value_label, classes: "text-right" },
      { label: pl_label, classes: "text-right" },
      { label: "Unrealized ROI", classes: "text-right" }
    ]) do |table| %>
      <% @positions.each do |pos| %>
        <% current_price = @current_prices[pos.ticker] %>
        <% unrealized = current_price && pos.breakeven ? (current_price.to_d - pos.breakeven.to_d) * pos.shares : nil %>
        <% market_value = current_price ? current_price.to_d * pos.shares : nil %>
        <% unrealized_roi = unrealized && pos.net_usd_invested.to_d.positive? ? (unrealized / pos.net_usd_invested.to_d * 100) : nil %>
        <% unrealized_usd = (@mep_rate && unrealized) ? (unrealized / @mep_rate) : nil %>
        <% table.with_row do %>
          <td class="whitespace-nowrap px-6 py-4 text-sm font-semibold text-slate-900"><%= pos.ticker %></td>
          <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-700">
            <% if pos.breakeven %>
              <%= @stock_portfolio.argentina? ? format_ars(pos.breakeven) : format_money(pos.breakeven) %>
            <% else %>
              —
            <% end %>
          </td>
          <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-700"><%= number_with_precision(pos.shares, precision: 6, strip_insignificant_zeros: true) %></td>
          <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-700">
            <%= current_price ? (@stock_portfolio.argentina? ? format_ars(current_price) : format_money(current_price)) : "—" %>
          </td>
          <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-700">
            <%= market_value ? (@stock_portfolio.argentina? ? format_ars(market_value) : format_money(market_value)) : "—" %>
          </td>
          <td class="whitespace-nowrap px-6 py-4 text-right text-sm <%= unrealized.nil? ? 'text-slate-500' : (unrealized >= 0 ? 'text-emerald-600' : 'text-red-600') %>">
            <% if unrealized.nil? %>
              —
            <% elsif @stock_portfolio.argentina? %>
              <%= format_ars(unrealized) %>
              <% if unrealized_usd %>
                <br><span class="text-xs text-slate-400">≈ <%= format_money(unrealized_usd) %> USD</span>
              <% end %>
            <% else %>
              <%= format_money(unrealized) %>
            <% end %>
          </td>
          <td class="whitespace-nowrap px-6 py-4 text-right text-sm <%= unrealized_roi.nil? ? 'text-slate-500' : (unrealized_roi >= 0 ? 'text-emerald-600' : 'text-red-600') %>"><%= unrealized_roi.nil? ? "—" : number_to_percentage(unrealized_roi, precision: 2) %></td>
        <% end %>
      <% end %>
    <% end %>
    <% if @stock_portfolio.argentina? %>
      <p class="mt-3 text-sm text-slate-500">Prices via Argentine market provider. Set your API key to enable live quotes.</p>
    <% else %>
      <p class="mt-3 text-sm text-slate-500">Prices via Finnhub. Set <code class="rounded bg-slate-100 px-1 text-xs">FINNHUB_API_KEY</code> to enable live quotes.</p>
    <% end %>
  <% else %>
    <%= render EmptyStateComponent.new(message: "No open stock positions yet. Add a buy trade above to get started.") %>
  <% end %>
  <% end %>

  <% if @view == "transactions" %>
    <%= form_with url: stocks_path, method: :get, local: true, class: "mb-4 flex flex-wrap items-end gap-4", data: { controller: "auto-submit-form", turbo: false } do |f| %>
      <%= f.hidden_field :view, value: "transactions" %>
      <%= hidden_field_tag :portfolio_id, @stock_portfolio.id %>
      <div class="flex flex-col gap-1">
        <%= f.label :from_date, "From", class: "text-sm font-medium text-slate-700" %>
        <%= f.date_field :from_date, value: @from_date, class: "rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500 w-auto min-w-[10rem]", data: { auto_submit_form_target: "trigger" } %>
      </div>
      <div class="flex flex-col gap-1">
        <%= f.label :to_date, "To", class: "text-sm font-medium text-slate-700" %>
        <%= f.date_field :to_date, value: @to_date, class: "rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500 w-auto min-w-[10rem]", data: { auto_submit_form_target: "trigger" } %>
      </div>
      <div class="flex flex-col gap-1">
        <%= f.label :ticker, "Ticker", class: "text-sm font-medium text-slate-700" %>
        <%= f.select :ticker, options_for_select([["All", ""]] + (@tickers_for_filter || []).map { |t| [t, t] }, @filter_ticker), {}, { class: "rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500 w-auto min-w-[8rem]", data: { auto_submit_form_target: "trigger" } } %>
      </div>
      <div class="flex flex-col gap-1">
        <%= f.label :side, "Side", class: "text-sm font-medium text-slate-700" %>
        <%= f.select :side, options_for_select([["All", ""], ["Buy", "buy"], ["Sell", "sell"]], @filter_side), {}, { class: "rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500 w-auto min-w-[6rem]", data: { auto_submit_form_target: "trigger" } } %>
      </div>
      <div class="flex flex-col gap-1">
        <span class="text-sm font-medium text-slate-700">&nbsp;</span>
        <div class="flex gap-2">
          <%= f.submit "Filter", class: "rounded-md bg-slate-800 px-3 py-2 text-sm font-medium text-white hover:bg-slate-700 focus:outline-none focus:ring-2 focus:ring-slate-500" %>
          <%= link_to "Clear filters", stocks_path(view: "transactions", portfolio_id: @stock_portfolio.id), class: "rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-slate-500" %>
        </div>
      </div>
    <% end %>

    <% if @trades.present? %>
      <% price_col = @stock_portfolio.argentina? ? "Price (ARS)" : "Price (USD)" %>
      <% total_col = @stock_portfolio.argentina? ? "Total value (ARS)" : "Total value (USD)" %>
      <%= render DataTableComponent.new(columns: [
        { label: "Date", classes: "text-left" },
        { label: "Ticker", classes: "text-left" },
        { label: "Side", classes: "text-left" },
        { label: @stock_portfolio.argentina? ? "CEDEAR units" : "Shares", classes: "text-right" },
        { label: price_col, classes: "text-right" },
        { label: total_col, classes: "text-right" }
      ]) do |table| %>
        <% @trades.each do |trade| %>
          <% table.with_row(classes: trade.side == "buy" ? "bg-emerald-50/50" : "bg-red-50/50") do %>
            <td class="whitespace-nowrap px-6 py-4 text-sm text-slate-700"><%= trade.executed_at.strftime("%b %d, %Y") %></td>
            <td class="whitespace-nowrap px-6 py-4 text-sm font-semibold text-slate-900"><%= trade.ticker %></td>
            <td class="whitespace-nowrap px-6 py-4 text-sm font-medium capitalize <%= trade.side == 'buy' ? 'text-emerald-700' : 'text-red-700' %>"><%= trade.side %></td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-700"><%= number_with_precision(trade.shares, precision: 6, strip_insignificant_zeros: true) %></td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-700">
              <%= @stock_portfolio.argentina? ? format_ars(trade.price_usd) : format_money(trade.price_usd) %>
            </td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-700">
              <%= @stock_portfolio.argentina? ? format_ars(trade.total_value_usd) : format_money(trade.total_value_usd) %>
            </td>
          <% end %>
        <% end %>
      <% end %>
      <% if @pagy.last > 1 %>
        <div class="mt-4 flex justify-center">
          <%== @pagy.series_nav %>
        </div>
      <% end %>
    <% else %>
      <%= render EmptyStateComponent.new(message: "No stock trades yet.") %>
    <% end %>
  <% end %>
</div>
