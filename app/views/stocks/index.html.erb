<div>
  <%= render PageHeaderComponent.new(title: "Stock portfolio") do |c| %>
    <% c.with_actions do %>
      <% if @all_portfolios.size > 1 %>
        <div class="flex items-center gap-2">
          <%= label_tag :portfolio_id, "Portfolio:", class: "text-sm text-slate-600" %>
          <%= select_tag :portfolio_id,
                options_for_select(@all_portfolios.map { |p| [p.name, p.id] }, @stock_portfolio.id),
                onchange: "window.location.href='#{stocks_path}?portfolio_id=' + this.value",
                class: "rounded-md border border-slate-300 px-3 py-1.5 text-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
        </div>
      <% end %>
      <%= render ButtonComponent.new(label: "Manage portfolios", href: stock_portfolios_path) %>
    <% end %>
  <% end %>

  <% if @stock_portfolio.argentina? %>
    <div class="mb-4 flex flex-wrap items-center gap-3">
      <% if @mep_rate %>
        <span class="inline-flex items-center rounded-full bg-blue-50 px-3 py-1 text-xs font-medium text-blue-700 ring-1 ring-inset ring-blue-600/20">
          MEP: <%= format_ars(@mep_rate) %> ARS/USD
        </span>
      <% else %>
        <span class="inline-flex items-center rounded-full bg-amber-50 px-3 py-1 text-xs font-medium text-amber-700 ring-1 ring-inset ring-amber-600/20">
          MEP rate unavailable — USD estimates hidden
        </span>
      <% end %>
      <%= link_to "Manage CEDEAR instruments", cedear_instruments_path, class: "text-sm text-slate-500 hover:text-slate-800" %>
    </div>
  <% end %>

  <%= render TabNavComponent.new(tabs: [
    { label: "Portfolio",   url: stocks_path(stocks_index_filter_params.merge("view" => "portfolio",   "portfolio_id" => @stock_portfolio.id)), active: @view == "portfolio" },
    { label: "Transactions", url: stocks_path(stocks_index_filter_params.merge("view" => "transactions", "portfolio_id" => @stock_portfolio.id)), active: @view == "transactions" },
    { label: "Performance",  url: stocks_path(stocks_index_filter_params.merge("view" => "performance",  "portfolio_id" => @stock_portfolio.id)), active: @view == "performance" },
    { label: "Valuations",   url: stocks_path(stocks_index_filter_params.merge("view" => "valuations",   "portfolio_id" => @stock_portfolio.id)), active: @view == "valuations" },
    { label: "Watch List",   url: stocks_path(view: "watchlist"), active: @view == "watchlist" }
  ]) %>

  <% if @view == "portfolio" %>
  <div class="mb-6 flex flex-wrap items-center gap-3">
    <%= render ModalComponent.new(title: "New trade", trigger_label: "New trade", open_on_connect: @open_new_trade_modal.present?) do %>
      <%= form_with url: stocks_trades_path, method: :post, local: true, data: { turbo: false, controller: @stock_portfolio.argentina? ? "cedear-ratio" : nil, "cedear-ratio-lookup-url-value": lookup_cedear_instruments_path } do |f| %>
        <%= hidden_field_tag :portfolio_id, @stock_portfolio.id %>
        <div class="space-y-4">
          <div>
            <%= f.label :side, "Side", class: "block text-sm font-medium text-slate-700" %>
            <%= f.select :side, options_for_select([["Buy", "buy"], ["Sell", "sell"]], @stock_trade&.side), { include_blank: "Select" }, class: "w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
            <% if @stock_trade&.errors&.key?(:side) %>
              <p class="mt-1 text-sm text-red-600"><%= @stock_trade.errors[:side].first %></p>
            <% end %>
          </div>
          <div>
            <%= f.label :ticker, @stock_portfolio.argentina? ? "Ticker (BCBA)" : "Ticker", class: "block text-sm font-medium text-slate-700" %>
            <%= f.text_field :ticker, value: @stock_trade&.ticker, placeholder: "e.g. AAPL", autocomplete: "off",
                  data: @stock_portfolio.argentina? ? { "cedear-ratio-target": "ticker", action: "blur->cedear-ratio#tickerChanged" } : {},
                  class: "w-full rounded-md border border-slate-300 px-3 py-2 text-sm uppercase focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
            <% if @stock_trade&.errors&.key?(:ticker) %>
              <p class="mt-1 text-sm text-red-600"><%= @stock_trade.errors[:ticker].first %></p>
            <% end %>
          </div>
          <div>
            <%= f.label :shares, @stock_portfolio.argentina? ? "Quantity" : "Shares", class: "block text-sm font-medium text-slate-700" %>
            <%= f.number_field :shares, value: @stock_trade&.shares, step: :any, min: 0, placeholder: "0", class: "w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
            <% if @stock_trade&.errors&.key?(:shares) %>
              <p class="mt-1 text-sm text-red-600"><%= @stock_trade.errors[:shares].first %></p>
            <% end %>
          </div>
          <div>
            <%= f.label :price_usd, @stock_portfolio.argentina? ? "Price (ARS)" : "Price (USD)", class: "block text-sm font-medium text-slate-700" %>
            <%= f.number_field :price_usd, value: @stock_trade&.price_usd, step: :any, min: 0, placeholder: "0.00", class: "w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
            <% if @stock_trade&.errors&.key?(:price_usd) %>
              <p class="mt-1 text-sm text-red-600"><%= @stock_trade.errors[:price_usd].first %></p>
            <% end %>
          </div>
          <% if @stock_portfolio.argentina? %>
          <div>
            <label class="block text-sm font-medium text-slate-700">CEDEAR ratio <span class="font-normal text-slate-500">(CEDEARs only, auto-filled)</span></label>
            <input type="number" step="any" min="0" placeholder="e.g. 10"
                   data-cedear-ratio-target="ratio"
                   class="w-full rounded-md border border-slate-300 bg-slate-50 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500"
                   disabled>
            <p class="mt-1 text-xs text-slate-500">Auto-filled from your CEDEAR instruments list. Leave blank for regular Argentine stocks.</p>
          </div>
          <% end %>
          <div>
            <%= f.label :executed_at, "Date & time", class: "block text-sm font-medium text-slate-700" %>
            <%= f.datetime_local_field :executed_at, value: @stock_trade&.executed_at&.strftime("%Y-%m-%dT%H:%M"), class: "w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
            <p class="mt-1 text-xs text-slate-500">Interpreted in <%= Time.zone.name %> and stored in UTC.</p>
            <% if @stock_trade&.errors&.key?(:executed_at) %>
              <p class="mt-1 text-sm text-red-600"><%= @stock_trade.errors[:executed_at].first %></p>
            <% end %>
          </div>
        </div>
        <div class="mt-6 flex gap-2">
          <%= f.submit "Add trade", class: "rounded-md bg-slate-800 px-4 py-2 text-sm font-medium text-white hover:bg-slate-700 focus:outline-none focus:ring-2 focus:ring-slate-500" %>
          <button type="button" data-action="dialog#close" class="rounded-md border border-slate-300 bg-white px-4 py-2 text-sm text-slate-700 hover:bg-slate-50">Cancel</button>
        </div>
      <% end %>
    <% end %>
  </div>

  <% if @positions.any? %>
  <div>
    <% if @stock_portfolio.argentina? %>
      <%# ── Argentina stat cards ── %>
      <%
        total_positions_ars = @stocks_value - @cash_balance
        total_positions_usd = @mep_rate&.positive? ? (total_positions_ars / @mep_rate) : nil
        pnl_usd             = @mep_rate&.positive? ? (@total_unrealized_pnl / @mep_rate) : nil
        cash_usd_stat       = @mep_rate&.positive? ? (@cash_balance / @mep_rate) : nil
      %>
      <%= render SummaryStatRowComponent.new(mb: 6) do %>
        <%= render StatCardComponent.new(label: "Stocks (ARS)", value: format_ars(total_positions_ars)) %>
        <%= render StatCardComponent.new(label: "Stocks (USD)", value: total_positions_usd ? format_money(total_positions_usd) : nil) %>
        <%= render StatCardComponent.new(label: "Unrealized P&L (ARS)", value: format_ars(@total_unrealized_pnl), signed: true, color_value: @total_unrealized_pnl) %>
        <%= render StatCardComponent.new(label: "Unrealized P&L (USD)", value: pnl_usd ? format_money(pnl_usd) : nil, signed: true, color_value: pnl_usd) %>
        <%= render StatCardComponent.new(label: "Cash (ARS)", value: format_ars(@cash_balance)) %>
        <%= render StatCardComponent.new(label: "Cash (USD)", value: cash_usd_stat ? format_money(cash_usd_stat) : nil) %>
      <% end %>
    <% else %>
      <%# ── US stat cards ── %>
      <%= render SummaryStatRowComponent.new(mb: 6) do %>
        <%= render StatCardComponent.new(label: "Stocks (USD)", value: format_money(@stocks_value - @cash_balance)) %>
        <%= render StatCardComponent.new(label: "Unrealized P&L", value: format_money(@total_unrealized_pnl), signed: true, color_value: @total_unrealized_pnl) %>
        <%= render StatCardComponent.new(label: "Cash (USD)", value: format_money(@cash_balance)) %>
      <% end %>
    <% end %>


    <% if @stock_portfolio.argentina? %>
      <%# ── Argentina CEDEAR portfolio table ── %>
      <% total_ars = @stocks_value %>
      <%= render DataTableComponent.new(columns: [
        { label: "Ticker",        classes: "text-left" },
        { label: "Ratio",         classes: "text-right" },
        { label: "Quantity",      classes: "text-right" },
        { label: "Avg buy price", classes: "text-right" },
        { label: "Price (ARS)",   classes: "text-right" },
        { label: "Price (USD)",   classes: "text-right" },
        { label: "Total (ARS)",   classes: "text-right" },
        { label: "Total (USD)",   classes: "text-right" },
        { label: "% / Total",     classes: "text-right" },
        { label: "% PnL",         classes: "text-right" }
      ]) do |table| %>
        <% @positions.each do |pos| %>
          <% current_price_ars = @current_prices[pos.ticker] %>
          <% current_price_usd = (@mep_rate && current_price_ars) ? (current_price_ars / @mep_rate) : nil %>
          <% total_pos_ars = current_price_ars ? current_price_ars.to_d * pos.shares : nil %>
          <% total_pos_usd = (@mep_rate && total_pos_ars) ? (total_pos_ars / @mep_rate) : nil %>
          <% pct_total = (total_pos_ars && total_ars&.positive?) ? (total_pos_ars / total_ars * 100) : nil %>
          <% pct_pnl = (current_price_ars && pos.breakeven&.positive?) ? ((current_price_ars.to_d - pos.breakeven.to_d) / pos.breakeven.to_d * 100) : nil %>
          <% ratio = @cedear_instruments[pos.ticker]&.ratio %>
          <% table.with_row do %>
            <td class="whitespace-nowrap px-6 py-4 text-sm font-semibold text-slate-900"><%= pos.ticker %></td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-700"><%= ratio ? number_with_precision(ratio, precision: 4, strip_insignificant_zeros: true) : "—" %></td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-700"><%= number_with_precision(pos.shares, precision: 6, strip_insignificant_zeros: true) %></td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-700"><%= pos.breakeven ? format_ars(pos.breakeven) : "—" %></td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-700"><%= current_price_ars ? format_ars(current_price_ars) : "—" %></td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-700"><%= current_price_usd ? format_money(current_price_usd) : "—" %></td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-700"><%= total_pos_ars ? format_ars(total_pos_ars) : "—" %></td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-700"><%= total_pos_usd ? format_money(total_pos_usd) : "—" %></td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-500"><%= pct_total ? number_to_percentage(pct_total, precision: 1) : "—" %></td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm <%= pct_pnl.nil? ? 'text-slate-500' : (pct_pnl >= 0 ? 'text-emerald-600' : 'text-red-600') %>"><%= pct_pnl ? number_to_percentage(pct_pnl, precision: 2) : "—" %></td>
          <% end %>
        <% end %>
        <% if @cash_balance.nonzero? %>
          <% cash_usd = (@mep_rate && @cash_balance) ? (@cash_balance / @mep_rate) : nil %>
          <% cash_pct_total = @stocks_value.positive? ? (@cash_balance / @stocks_value * 100) : nil %>
          <% table.with_row do %>
            <td class="whitespace-nowrap px-6 py-4 text-sm font-semibold text-slate-900">CASH</td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-400">—</td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-400">—</td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-400">—</td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-400">—</td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-400">—</td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm <%= @cash_balance.negative? ? 'text-red-600' : 'text-slate-700' %>"><%= format_ars(@cash_balance) %></td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-700"><%= cash_usd ? format_money(cash_usd) : "—" %></td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-500"><%= cash_pct_total ? number_to_percentage(cash_pct_total, precision: 1) : "—" %></td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-400">—</td>
          <% end %>
        <% end %>
        <%# ── Totals row ── %>
        <% total_usd = @mep_rate&.positive? ? (@stocks_value / @mep_rate).round(2) : nil %>
        <% table.with_row(classes: "border-t-2 border-slate-200 bg-slate-50") do %>
          <td class="whitespace-nowrap px-6 py-4 text-sm font-bold text-slate-900">TOTAL</td>
          <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-400">—</td>
          <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-400">—</td>
          <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-400">—</td>
          <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-400">—</td>
          <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-400">—</td>
          <td class="whitespace-nowrap px-6 py-4 text-right text-sm font-bold text-slate-900"><%= format_ars(@stocks_value) %></td>
          <td class="whitespace-nowrap px-6 py-4 text-right text-sm font-bold text-slate-900"><%= total_usd ? format_money(total_usd) : "—" %></td>
          <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-400">—</td>
          <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-400">—</td>
        <% end %>
      <% end %>
      <% unless Stocks::IolClient.credentials %>
        <p class="mt-3 text-sm text-slate-500">Set <code class="rounded bg-slate-100 px-1 text-xs">IOL_USERNAME</code> and <code class="rounded bg-slate-100 px-1 text-xs">IOL_PASSWORD</code> to enable live quotes.</p>
      <% end %>
    <% else %>
      <%# ── US stock portfolio table ── %>
      <%= render DataTableComponent.new(columns: [
        { label: "Ticker",         classes: "text-left" },
        { label: "Avg cost",       classes: "text-right" },
        { label: "Shares",         classes: "text-right" },
        { label: "Current price",  classes: "text-right" },
        { label: "Market value",   classes: "text-right" },
        { label: "% / Total",      classes: "text-right" },
        { label: "Unrealized P&L", classes: "text-right" },
        { label: "Unrealized ROI", classes: "text-right" }
      ]) do |table| %>
        <% @positions.each do |pos| %>
          <% current_price = @current_prices[pos.ticker] %>
          <% unrealized = current_price && pos.breakeven ? (current_price.to_d - pos.breakeven.to_d) * pos.shares : nil %>
          <% market_value = current_price ? current_price.to_d * pos.shares : nil %>
          <% pct_total = (market_value && @stocks_value.positive?) ? (market_value / @stocks_value * 100) : nil %>
          <% unrealized_roi = unrealized && pos.net_usd_invested.to_d.positive? ? (unrealized / pos.net_usd_invested.to_d * 100) : nil %>
          <% table.with_row do %>
            <td class="whitespace-nowrap px-6 py-4 text-sm font-semibold text-slate-900"><%= pos.ticker %></td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-700"><%= pos.breakeven ? format_money(pos.breakeven) : "—" %></td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-700"><%= number_with_precision(pos.shares, precision: 6, strip_insignificant_zeros: true) %></td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-700"><%= current_price ? format_money(current_price) : "—" %></td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-700"><%= market_value ? format_money(market_value) : "—" %></td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-500"><%= pct_total ? number_to_percentage(pct_total, precision: 1) : "—" %></td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm <%= unrealized.nil? ? 'text-slate-500' : (unrealized >= 0 ? 'text-emerald-600' : 'text-red-600') %>"><%= unrealized ? format_money(unrealized) : "—" %></td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm <%= unrealized_roi.nil? ? 'text-slate-500' : (unrealized_roi >= 0 ? 'text-emerald-600' : 'text-red-600') %>"><%= unrealized_roi ? number_to_percentage(unrealized_roi, precision: 2) : "—" %></td>
          <% end %>
        <% end %>
        <% if @cash_balance.nonzero? %>
          <% cash_pct_total = @stocks_value.positive? ? (@cash_balance / @stocks_value * 100) : nil %>
          <% table.with_row do %>
            <td class="whitespace-nowrap px-6 py-4 text-sm font-semibold text-slate-900">CASH</td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-400">—</td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-400">—</td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-400">—</td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm <%= @cash_balance.negative? ? 'text-red-600' : 'text-slate-700' %>"><%= format_money(@cash_balance) %></td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-500"><%= cash_pct_total ? number_to_percentage(cash_pct_total, precision: 1) : "—" %></td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-400">—</td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-400">—</td>
          <% end %>
        <% end %>
        <%# ── Totals row ── %>
        <% table.with_row(classes: "border-t-2 border-slate-200 bg-slate-50") do %>
          <td class="whitespace-nowrap px-6 py-4 text-sm font-bold text-slate-900">TOTAL</td>
          <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-400">—</td>
          <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-400">—</td>
          <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-400">—</td>
          <td class="whitespace-nowrap px-6 py-4 text-right text-sm font-bold text-slate-900"><%= format_money(@stocks_value) %></td>
          <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-400">—</td>
          <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-400">—</td>
          <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-400">—</td>
        <% end %>
      <% end %>
      <p class="mt-3 text-sm text-slate-500">Prices via Finnhub. Set <code class="rounded bg-slate-100 px-1 text-xs">FINNHUB_API_KEY</code> to enable live quotes.</p>
    <% end %>
    <% if @stocks_chart_data[:pie].any? || @stocks_chart_data[:bar].any? %>
      <%= content_tag :div,
            class: "mt-6 grid grid-cols-1 gap-6 lg:grid-cols-2",
            data: { controller: "stocks-charts", "stocks-charts-data-value": @stocks_chart_data.to_json } do %>
        <div class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
          <p class="mb-3 text-sm font-medium text-slate-700">Portfolio allocation</p>
          <div class="h-52">
            <canvas data-stocks-charts-target="pieCanvas"></canvas>
            <p class="hidden text-sm text-slate-500" data-stocks-charts-target="pieEmpty">No price data available.</p>
          </div>
        </div>
        <div class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
          <p class="mb-3 text-sm font-medium text-slate-700">Unrealized P&L by ticker</p>
          <div class="h-52">
            <canvas data-stocks-charts-target="barCanvas"></canvas>
            <p class="hidden text-sm text-slate-500" data-stocks-charts-target="barEmpty">No price data available.</p>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
  <% else %>
    <%= render EmptyStateComponent.new(message: "No open stock positions yet. Add a buy trade above to get started.") %>
  <% end %>
  <% end %>

  <% if @view == "transactions" %>
    <%= form_with url: stocks_path, method: :get, local: true, class: "mb-4 flex flex-wrap items-end gap-4", data: { controller: "auto-submit-form", turbo: false } do |f| %>
      <%= f.hidden_field :view, value: "transactions" %>
      <%= hidden_field_tag :portfolio_id, @stock_portfolio.id %>
      <div class="flex flex-col gap-1">
        <%= f.label :from_date, "From", class: "text-sm font-medium text-slate-700" %>
        <%= f.date_field :from_date, value: @from_date, class: "rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500 w-auto min-w-[10rem]", data: { auto_submit_form_target: "trigger" } %>
      </div>
      <div class="flex flex-col gap-1">
        <%= f.label :to_date, "To", class: "text-sm font-medium text-slate-700" %>
        <%= f.date_field :to_date, value: @to_date, class: "rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500 w-auto min-w-[10rem]", data: { auto_submit_form_target: "trigger" } %>
      </div>
      <div class="flex flex-col gap-1">
        <%= f.label :ticker, "Ticker", class: "text-sm font-medium text-slate-700" %>
        <%= f.select :ticker, options_for_select([["All", ""]] + (@tickers_for_filter || []).map { |t| [t, t] }, @filter_ticker), {}, { class: "rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500 w-auto min-w-[8rem]", data: { auto_submit_form_target: "trigger" } } %>
      </div>
      <div class="flex flex-col gap-1">
        <%= f.label :side, "Side", class: "text-sm font-medium text-slate-700" %>
        <%= f.select :side, options_for_select([["All", ""], ["Buy", "buy"], ["Sell", "sell"]], @filter_side), {}, { class: "rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500 w-auto min-w-[6rem]", data: { auto_submit_form_target: "trigger" } } %>
      </div>
      <div class="flex flex-col gap-1">
        <span class="text-sm font-medium text-slate-700">&nbsp;</span>
        <div class="flex gap-2">
          <%= f.submit "Filter", class: "rounded-md bg-slate-800 px-3 py-2 text-sm font-medium text-white hover:bg-slate-700 focus:outline-none focus:ring-2 focus:ring-slate-500" %>
          <%= link_to "Clear filters", stocks_path(view: "transactions", portfolio_id: @stock_portfolio.id), class: "rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-slate-500" %>
        </div>
      </div>
    <% end %>

    <% if @trades.present? %>
      <% price_col = @stock_portfolio.argentina? ? "Price (ARS)" : "Price (USD)" %>
      <% total_col = @stock_portfolio.argentina? ? "Total value (ARS)" : "Total value (USD)" %>
      <%= render DataTableComponent.new(columns: [
        { label: "Date", classes: "text-left" },
        { label: "Ticker", classes: "text-left" },
        { label: "Side", classes: "text-left" },
        { label: @stock_portfolio.argentina? ? "Quantity" : "Shares", classes: "text-right" },
        { label: price_col, classes: "text-right" },
        { label: total_col, classes: "text-right" }
      ]) do |table| %>
        <% @trades.each do |trade| %>
          <% table.with_row(classes: trade.side == "buy" ? "bg-emerald-50/50" : "bg-red-50/50") do %>
            <td class="whitespace-nowrap px-6 py-4 text-sm text-slate-700"><%= trade.executed_at.strftime("%b %d, %Y") %></td>
            <td class="whitespace-nowrap px-6 py-4 text-sm font-semibold text-slate-900"><%= trade.ticker %></td>
            <td class="whitespace-nowrap px-6 py-4 text-sm font-medium capitalize <%= trade.side == 'buy' ? 'text-emerald-700' : 'text-red-700' %>"><%= trade.side %></td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-700"><%= number_with_precision(trade.shares, precision: 6, strip_insignificant_zeros: true) %></td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-700">
              <%= @stock_portfolio.argentina? ? format_ars(trade.price_usd) : format_money(trade.price_usd) %>
            </td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-700">
              <%= @stock_portfolio.argentina? ? format_ars(trade.total_value_usd) : format_money(trade.total_value_usd) %>
            </td>
          <% end %>
        <% end %>
      <% end %>
      <% if @pagy.last > 1 %>
        <div class="mt-4 flex justify-center">
          <%== @pagy.series_nav %>
        </div>
      <% end %>
    <% else %>
      <%= render EmptyStateComponent.new(message: "No stock trades yet.") %>
    <% end %>
  <% end %>

  <% if @view == "performance" %>
    <div class="mb-6 flex flex-wrap items-center gap-3">
      <%= render ModalComponent.new(title: "Record entry", trigger_label: "Record entry") do %>
        <%= form_with url: stocks_snapshots_path, method: :post, local: true, data: { turbo: false, controller: "performance-entry" } do |f| %>
          <%= hidden_field_tag :portfolio_id, @stock_portfolio.id %>
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-slate-700">Type</label>
              <div class="mt-1 flex gap-4">
                <label class="flex items-center gap-2 text-sm">
                  <%= radio_button_tag :entry_type, "snapshot", true, data: { action: "change->performance-entry#typeChanged", "performance-entry-target": "type" }, class: "text-slate-800" %>
                  Snapshot only
                </label>
                <label class="flex items-center gap-2 text-sm">
                  <%= radio_button_tag :entry_type, "deposit", false, data: { action: "change->performance-entry#typeChanged", "performance-entry-target": "type" }, class: "text-slate-800" %>
                  Deposit
                </label>
                <label class="flex items-center gap-2 text-sm">
                  <%= radio_button_tag :entry_type, "withdrawal", false, data: { action: "change->performance-entry#typeChanged", "performance-entry-target": "type" }, class: "text-slate-800" %>
                  Withdrawal
                </label>
              </div>
            </div>
            <div data-performance-entry-target="amountField" class="hidden">
              <label class="block text-sm font-medium text-slate-700">
                Amount (<%= @stock_portfolio.argentina? ? "ARS" : "USD" %>)
              </label>
              <input type="number" name="cash_flow_amount" step="any" min="0" placeholder="0"
                     class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500">
              <p class="mt-1 text-xs text-slate-500">Enter a positive amount — direction is set by the type above.</p>
            </div>
            <p class="text-xs text-slate-500">Current portfolio value will be fetched automatically from live prices.</p>
          </div>
          <div class="mt-6 flex gap-2">
            <button type="submit" class="rounded-md bg-slate-800 px-4 py-2 text-sm font-medium text-white hover:bg-slate-700 focus:outline-none focus:ring-2 focus:ring-slate-500">Save</button>
            <button type="button" data-action="dialog#close" class="rounded-md border border-slate-300 bg-white px-4 py-2 text-sm text-slate-700 hover:bg-slate-50">Cancel</button>
          </div>
        <% end %>
      <% end %>
    </div>

    <% twr_data = { twr: @twr_series.map { |p| { date: p.date, twr_pct: p.twr_pct } } } %>
    <%= content_tag :div,
          data: { controller: "stocks-charts", "stocks-charts-data-value": twr_data.to_json } do %>
      <div class="mb-6 rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
        <p class="mb-3 text-sm font-medium text-slate-700">Time-Weighted Return (%)</p>
        <div class="h-56">
          <canvas data-stocks-charts-target="twrCanvas"></canvas>
          <p class="hidden text-sm text-slate-500" data-stocks-charts-target="twrEmpty">No snapshots yet. Record at least two entries to see the chart.</p>
        </div>
      </div>
    <% end %>

    <% if @snapshots.any? %>
      <%= render DataTableComponent.new(columns: [
        { label: "Date", classes: "text-left" },
        { label: "Type", classes: "text-left" },
        { label: "Cash flow", classes: "text-right" },
        { label: "Portfolio value", classes: "text-right" },
        { label: "Source", classes: "text-left" },
        { label: "", classes: "text-right" }
      ]) do |table| %>
        <% @snapshots.each do |snap| %>
          <% table.with_row do %>
            <td class="whitespace-nowrap px-6 py-4 text-sm text-slate-700"><%= snap.recorded_at.strftime("%b %d, %Y %H:%M") %></td>
            <td class="whitespace-nowrap px-6 py-4 text-sm text-slate-700">
              <% if snap.deposit? %>
                <span class="inline-flex items-center rounded-full bg-emerald-50 px-2 py-0.5 text-xs font-medium text-emerald-700">Deposit</span>
              <% elsif snap.withdrawal? %>
                <span class="inline-flex items-center rounded-full bg-red-50 px-2 py-0.5 text-xs font-medium text-red-700">Withdrawal</span>
              <% else %>
                <span class="inline-flex items-center rounded-full bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-600">Snapshot</span>
              <% end %>
            </td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm <%= snap.snapshot_only? ? 'text-slate-400' : (snap.deposit? ? 'text-emerald-600' : 'text-red-600') %>">
              <% if snap.snapshot_only? %>
                —
              <% elsif @stock_portfolio.argentina? %>
                <%= snap.deposit? ? "+" : "−" %><%= format_ars(snap.cash_flow.abs) %>
              <% else %>
                <%= snap.deposit? ? "+" : "−" %><%= format_money(snap.cash_flow.abs) %>
              <% end %>
            </td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-700">
              <%= @stock_portfolio.argentina? ? format_ars(snap.total_value) : format_money(snap.total_value) %>
            </td>
            <td class="whitespace-nowrap px-6 py-4 text-sm capitalize text-slate-500"><%= snap.source %></td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm">
              <%= button_to "Delete", stocks_snapshot_path(id: snap.id, portfolio_id: @stock_portfolio.id),
                    method: :delete,
                    data: { turbo_confirm: "Delete this entry?" },
                    class: "text-slate-400 hover:text-red-600 text-xs" %>
            </td>
          <% end %>
        <% end %>
      <% end %>
    <% else %>
      <%= render EmptyStateComponent.new(message: "No entries yet. Record a snapshot or cash flow to start tracking TWR.") %>
    <% end %>
  <% end %>

  <% if @view == "valuations" %>
    <% if @positions.empty? %>
      <%= render EmptyStateComponent.new(message: "No open positions to show valuations for.") %>
    <% else %>
      <%= render "stocks/fundamentals_table",
            tickers:       @positions.map(&:ticker),
            fundamentals:  @fundamentals,
            sync_url:      stocks_sync_fundamentals_path(portfolio_id: @stock_portfolio.id),
            analyses:      @analyses %>
    <% end %>
  <% end %>

  <% if @view == "watchlist" %>
    <%= form_with url: stocks_watchlist_path, method: :post, class: "mb-4 flex gap-2" do |f| %>
      <%= f.text_field :ticker,
            placeholder: "e.g. NVDA",
            class: "rounded-md border border-slate-300 px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-slate-500 uppercase",
            autocomplete: "off",
            required: true %>
      <%= f.submit "Add",
            class: "rounded-md bg-slate-800 px-3 py-1.5 text-sm font-medium text-white hover:bg-slate-700 cursor-pointer" %>
    <% end %>
    <% if @watchlist_tickers.empty? %>
      <%= render EmptyStateComponent.new(message: "No tickers yet — add one above.") %>
    <% else %>
      <%= render "stocks/fundamentals_table",
            tickers:         @watchlist_tickers.map(&:ticker),
            fundamentals:    @fundamentals,
            sync_url:        stocks_watchlist_sync_path,
            watchlist_items: @watchlist_tickers.index_by(&:ticker),
            analyses:        @analyses %>
    <% end %>
  <% end %>
</div>
