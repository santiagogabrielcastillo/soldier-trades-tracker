<turbo-frame id="pe-thresholds-edit">
  <%= form_with model: @threshold,
        url: stocks_sector_pe_threshold_path(CGI.escape(@threshold.sector), ticker: params[:ticker]),
        method: :patch,
        class: "mt-3 rounded-md border border-slate-200 bg-slate-50 p-4" do |f| %>
    <p class="mb-3 text-xs font-semibold uppercase tracking-wide text-slate-500">
      Edit thresholds — <%= @threshold.sector %>
    </p>

    <% if @threshold.errors.any? %>
      <ul class="mb-3 text-xs text-red-600 space-y-0.5">
        <% @threshold.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    <% end %>

    <div class="grid grid-cols-3 gap-3">
      <div>
        <label class="block text-xs font-medium text-slate-600 mb-1">Gift (&lt; x)</label>
        <%= f.number_field :gift_max, step: 0.5, min: 1,
              class: "w-full rounded border border-slate-300 px-2 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-slate-400" %>
      </div>
      <div>
        <label class="block text-xs font-medium text-slate-600 mb-1">Attractive (&lt; x)</label>
        <%= f.number_field :attractive_max, step: 0.5, min: 1,
              class: "w-full rounded border border-slate-300 px-2 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-slate-400" %>
      </div>
      <div>
        <label class="block text-xs font-medium text-slate-600 mb-1">Fair (≤ x)</label>
        <%= f.number_field :fair_max, step: 0.5, min: 1,
              class: "w-full rounded border border-slate-300 px-2 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-slate-400" %>
      </div>
    </div>

    <div class="mt-3 flex items-center gap-3">
      <%= f.submit "Save", class: "rounded-md bg-slate-800 px-3 py-1.5 text-xs font-medium text-white hover:bg-slate-700 cursor-pointer" %>
      <%= link_to "Cancel",
            stocks_valuation_check_path(ticker: params[:ticker]),
            class: "text-xs text-slate-500 hover:text-slate-700",
            data: { turbo_frame: "pe-thresholds-edit" } %>
    </div>
  <% end %>
</turbo-frame>
