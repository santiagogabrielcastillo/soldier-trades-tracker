<div>
  <%= render PageHeaderComponent.new(title: "Spot portfolio") %>

  <%= render TabNavComponent.new(tabs: [
    { label: "Portfolio", url: spot_path(spot_index_filter_params.merge("view" => "portfolio")), active: @view == "portfolio" },
    { label: "Transactions", url: spot_path(spot_index_filter_params.merge("view" => "transactions")), active: @view == "transactions" }
  ]) %>

  <% if @view == "portfolio" %>
  <div class="mb-6 flex flex-wrap items-center gap-3">
    <%= button_to "Sync prices", spot_sync_prices_path, method: :post, class: "rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-slate-500" %>
    <% if @prices_synced_at %>
      <span class="text-xs text-slate-400">Last synced <%= time_ago_in_words(@prices_synced_at) %> ago</span>
    <% else %>
      <span class="text-xs text-slate-400">Prices not synced yet</span>
    <% end %>
    <%= render ModalComponent.new(title: "New transaction", trigger_label: "New transaction", open_on_connect: @open_new_transaction_modal.present?) do %>
      <%= form_with url: spot_transactions_path, method: :post, local: true, data: { turbo: false, controller: "spot-transaction-form" } do |f| %>
        <div class="space-y-4">
          <div>
            <%= f.label :side, "Side", class: "block text-sm font-medium text-slate-700" %>
            <%= f.select :side, options_for_select([["Buy", "buy"], ["Sell", "sell"], ["Deposit", "deposit"], ["Withdraw", "withdraw"]], @spot_transaction&.side), { include_blank: "Select" }, class: "w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500", data: { action: "change->spot-transaction-form#togglePriceAndToken" } %>
            <% if @spot_transaction&.errors&.key?(:side) %>
              <p class="mt-1 text-sm text-red-600"><%= @spot_transaction.errors[:side].first %></p>
            <% end %>
          </div>
          <div data-spot-transaction-form-target="tokenWrapper">
            <div data-controller="spot-token-select" data-spot-token-select-tokens-value="<%= @tokens_for_select.to_json %>">
              <%= f.label :token, "Token", class: "block text-sm font-medium text-slate-700" %>
              <%= f.text_field :token, value: @spot_transaction&.token, placeholder: "Search or type...", autocomplete: "off", class: "w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500", data: { spot_token_select_target: "input", action: "input->spot-token-select#filter keydown->spot-token-select#keydown" } %>
              <% if @spot_transaction&.errors&.key?(:token) %>
                <p class="mt-1 text-sm text-red-600"><%= @spot_transaction.errors[:token].first %></p>
              <% end %>
              <ul id="spot-token-listbox" data-spot-token-select-target="listbox" data-action="click->spot-token-select#selectOption" class="max-h-48 overflow-y-auto rounded-md border border-slate-200 bg-white shadow-lg" aria-label="Token suggestions"></ul>
            </div>
          </div>
          <div>
            <%= f.label :amount, "Amount", class: "block text-sm font-medium text-slate-700" %>
            <%= f.number_field :amount, value: @spot_transaction&.amount, step: :any, min: 0, placeholder: "0", class: "w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
            <% if @spot_transaction&.errors&.key?(:amount) %>
              <p class="mt-1 text-sm text-red-600"><%= @spot_transaction.errors[:amount].first %></p>
            <% end %>
          </div>
          <div data-spot-transaction-form-target="priceWrapper">
            <%= f.label :price_usd, "Price (USD)", class: "block text-sm font-medium text-slate-700" %>
            <%= f.number_field :price_usd, value: @spot_transaction&.price_usd, step: :any, min: 0, placeholder: "0", class: "w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
            <% if @spot_transaction&.errors&.key?(:price_usd) %>
              <p class="mt-1 text-sm text-red-600"><%= @spot_transaction.errors[:price_usd].first %></p>
            <% end %>
          </div>
          <div>
            <%= f.label :executed_at, "Date & time", class: "block text-sm font-medium text-slate-700" %>
            <%= f.datetime_local_field :executed_at, value: @spot_transaction&.executed_at&.strftime("%Y-%m-%dT%H:%M"), class: "w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
            <p class="mt-1 text-xs text-slate-500">Interpreted in <%= Time.zone.name %> and stored in UTC.</p>
            <% if @spot_transaction&.errors&.key?(:executed_at) %>
              <p class="mt-1 text-sm text-red-600"><%= @spot_transaction.errors[:executed_at].first %></p>
            <% end %>
          </div>
        </div>
        <div class="mt-6 flex gap-2">
          <%= f.submit "Add transaction", class: "rounded-md bg-slate-800 px-4 py-2 text-sm font-medium text-white hover:bg-slate-700 focus:outline-none focus:ring-2 focus:ring-slate-500" %>
          <button type="button" data-action="dialog#close" class="rounded-md border border-slate-300 bg-white px-4 py-2 text-sm text-slate-700 hover:bg-slate-50">Cancel</button>
        </div>
      <% end %>
    <% end %>
  </div>

  <div class="mb-4 flex flex-wrap items-baseline gap-6">
    <div>
      <span class="text-sm text-slate-500">Cash balance</span>
      <p class="text-xl font-semibold <%= (@cash_balance || 0).to_d >= 0 ? 'text-slate-900' : 'text-red-600' %>"><%= format_money(@cash_balance || 0) %></p>
    </div>
    <div>
      <span class="text-sm text-slate-500">Cash % of portfolio</span>
      <p class="text-xl font-semibold text-slate-900"><%= @cash_pct.nil? ? "—" : "#{number_with_precision(@cash_pct, precision: 2)}%" %></p>
    </div>
  </div>

  <div class="mb-6">
    <%= form_with url: spot_import_path, method: :post, local: true, multipart: true, class: "flex flex-wrap items-end gap-3", data: { turbo: false } do |f| %>
      <%= f.file_field :csv_file, accept: "text/csv,application/csv,.csv", class: "rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
      <%= f.submit "Import CSV", class: "rounded-md bg-slate-800 px-4 py-2 text-sm font-medium text-white hover:bg-slate-700 focus:outline-none focus:ring-2 focus:ring-slate-500" %>
    <% end %>
    <p class="mt-2 text-sm text-slate-500">CSV columns: Date (UTC-3:00), Token, Type, Price (USD), Amount, Total value (USD), Fee, Fee Currency, Notes. Re-uploading the same file skips duplicates.</p>
  </div>

  <% if @positions.any? %>
    <%= render DataTableComponent.new(columns: [
      { label: "Token", classes: "text-left" },
      { label: "Net breakeven", classes: "text-right" },
      { label: "Gross avg price", classes: "text-right" },
      { label: "Current qty", classes: "text-right" },
      { label: "Current price", classes: "text-right" },
      { label: "Current net value", classes: "text-right" },
      { label: "Unrealized PnL", classes: "text-right" },
      { label: "ROI (net)", classes: "text-right" },
      { label: "ROI (avg)", classes: "text-right" },
      { label: "Status", classes: "text-left" }
    ]) do |table| %>
      <% @positions.each do |pos| %>
        <% current_price = @current_prices[pos.token] %>
        <% unrealized = pos.open? && current_price ? (current_price - pos.breakeven.to_d) * pos.balance : nil %>
        <% current_net_value = pos.open? && current_price ? (current_price.to_d * pos.balance) : nil %>
        <% unrealized_roi_net = unrealized && pos.net_usd_invested.to_d.positive? ? (unrealized / pos.net_usd_invested.to_d * 100) : nil %>
        <% unrealized_roi_avg = pos.open? && current_price && pos.gross_avg_price&.positive? ? ((current_price.to_d - pos.gross_avg_price) / pos.gross_avg_price * 100) : nil %>
        <% table.with_row do %>
          <td class="whitespace-nowrap px-6 py-4 text-sm font-medium text-slate-900"><%= pos.token %></td>
          <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-700"><%= pos.breakeven ? format_money(pos.breakeven) : "—" %></td>
          <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-700"><%= pos.gross_avg_price ? format_money(pos.gross_avg_price) : "—" %></td>
          <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-700"><%= number_with_delimiter(pos.balance, delimiter: ",", precision: 8) %></td>
          <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-700"><%= current_price ? format_money(current_price) : "—" %></td>
          <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-700"><%= current_net_value ? format_money(current_net_value) : "—" %></td>
          <td class="whitespace-nowrap px-6 py-4 text-right text-sm <%= unrealized.nil? ? 'text-slate-500' : (unrealized >= 0 ? 'text-emerald-600' : 'text-red-600') %>"><%= unrealized.nil? ? "—" : format_money(unrealized) %></td>
          <td class="whitespace-nowrap px-6 py-4 text-right text-sm <%= unrealized_roi_net.nil? ? 'text-slate-500' : (unrealized_roi_net >= 0 ? 'text-emerald-600' : 'text-red-600') %>"><%= unrealized_roi_net.nil? ? "—" : number_to_percentage(unrealized_roi_net, precision: 2) %></td>
          <td class="whitespace-nowrap px-6 py-4 text-right text-sm <%= unrealized_roi_avg.nil? ? 'text-slate-500' : (unrealized_roi_avg >= 0 ? 'text-emerald-600' : 'text-red-600') %>"><%= unrealized_roi_avg.nil? ? "—" : number_to_percentage(unrealized_roi_avg, precision: 2) %></td>
          <td class="whitespace-nowrap px-6 py-4 text-sm text-slate-600"><%= pos.open? ? "Open" : "Closed" %></td>
        <% end %>
      <% end %>
    <% end %>
    <% if current_user.exchange_accounts.empty? %>
      <p class="mt-4 text-sm text-slate-500">Connect an <%= link_to "exchange account", exchange_accounts_path, class: "text-slate-700 underline" %> to see live prices, current net value, and unrealized PnL/ROI.</p>
    <% end %>
  <% else %>
    <%= render EmptyStateComponent.new(message: "No spot positions yet. Upload a transaction history CSV above to get started.") %>
  <% end %>

  <%# Scenario calculator — always shown in portfolio view, collapsed by default %>
  <%= render "scenario_calculator" %>
  <% end %>

  <% if @view == "transactions" %>
    <%= render DateRangeFilterComponent.new(
          url: spot_path,
          from: @from_date,
          to: @to_date,
          extra_params: { view: "transactions" },
          clear_url: spot_path(view: "transactions")
        ) do |c| %>
      <% c.with_extra_fields do %>
        <div class="flex flex-col gap-1">
          <label for="token" class="text-sm font-medium text-slate-700">Token</label>
          <%= select_tag :token,
                options_for_select([["All", ""]] + (@tokens_for_filter || []).map { |t| [t, t] }, @filter_token),
                class: "rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500 w-auto min-w-[8rem]",
                data: { auto_submit_form_target: "trigger" } %>
        </div>
        <div class="flex flex-col gap-1">
          <label for="side" class="text-sm font-medium text-slate-700">Side</label>
          <%= select_tag :side,
                options_for_select([["All", ""], ["Buy", "buy"], ["Sell", "sell"], ["Deposit", "deposit"], ["Withdraw", "withdraw"]], @filter_side),
                class: "rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500 w-auto min-w-[6rem]",
                data: { auto_submit_form_target: "trigger" } %>
        </div>
      <% end %>
    <% end %>

    <% if @transactions.present? %>
      <%= render DataTableComponent.new(columns: [
        { label: "Date", classes: "text-left" },
        { label: "Token", classes: "text-left" },
        { label: "Side", classes: "text-left" },
        { label: "Amount", classes: "text-right" },
        { label: "Price (USD)", classes: "text-right" },
        { label: "Total value (USD)", classes: "text-right" },
        { label: "", classes: "text-right" }
      ]) do |table| %>
        <% @transactions.each do |tx| %>
          <% deposit_or_buy = tx.side == "buy" || tx.side == "deposit" %>
          <% table.with_row(classes: deposit_or_buy ? "bg-emerald-50/50" : "bg-red-50/50") do %>
            <td class="whitespace-nowrap px-6 py-4 text-sm text-slate-700"><%= tx.executed_at.strftime("%b %d, %Y") %></td>
            <td class="whitespace-nowrap px-6 py-4 text-sm font-medium text-slate-900"><%= tx.token %></td>
            <td class="whitespace-nowrap px-6 py-4 text-sm font-medium capitalize <%= deposit_or_buy ? 'text-emerald-700' : 'text-red-700' %>"><%= tx.side %></td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-700"><%= number_with_delimiter(tx.amount, delimiter: ",", precision: 8) %></td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-700"><%= tx.side.in?(%w[deposit withdraw]) ? "—" : format_money(tx.price_usd) %></td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-700"><%= format_money(tx.total_value_usd) %></td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm">
              <%= link_to "Edit", edit_spot_transaction_path(tx),
                  data: { turbo_frame: "spot-transaction-edit-frame" },
                  class: "mr-3 text-slate-500 underline hover:text-slate-800" %>
              <%= link_to "Delete", confirm_destroy_spot_transaction_path(tx),
                  data: { turbo_frame: "spot-transaction-delete-frame" },
                  class: "text-red-500 underline hover:text-red-700" %>
            </td>
          <% end %>
        <% end %>
      <% end %>
      <% if @pagy.last > 1 %>
        <div class="mt-4 flex justify-center">
          <%== @pagy.series_nav %>
        </div>
      <% end %>

    <% else %>
      <%= render EmptyStateComponent.new(message: "No spot transactions yet.") %>
    <% end %>

    <%# Shared edit modal — content loaded on demand via Turbo Frame %>
    <div data-controller="turbo-modal">
      <dialog data-turbo-modal-target="dialog"
              class="w-full max-w-md rounded-lg border border-slate-200 bg-white p-6 shadow-xl backdrop:bg-slate-900/20">
        <turbo-frame id="spot-transaction-edit-frame"
                     data-turbo-modal-target="frame"
                     data-action="turbo:frame-load->turbo-modal#open">
        </turbo-frame>
      </dialog>
    </div>

    <%# Shared delete confirm modal — content loaded on demand via Turbo Frame %>
    <div data-controller="turbo-modal">
      <dialog data-turbo-modal-target="dialog"
              class="w-full max-w-md rounded-lg border border-slate-200 bg-white p-6 shadow-xl backdrop:bg-slate-900/20">
        <turbo-frame id="spot-transaction-delete-frame"
                     data-turbo-modal-target="frame"
                     data-action="turbo:frame-load->turbo-modal#open">
        </turbo-frame>
      </dialog>
    </div>
  <% end %>
</div>
