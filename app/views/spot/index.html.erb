<div>
  <h1 class="mb-4 text-2xl font-semibold text-slate-900">Spot portfolio</h1>

  <nav class="mb-6 flex gap-1 border-b border-slate-200" aria-label="Tabs">
    <%= link_to "Portfolio", spot_path(spot_index_filter_params.merge("view" => "portfolio")), class: "border-b-2 px-4 py-2 text-sm font-medium #{@view == 'portfolio' ? 'border-slate-800 text-slate-900' : 'border-transparent text-slate-500 hover:border-slate-300 hover:text-slate-700'}", **(@view == 'portfolio' ? { 'aria-current': 'page' } : {}) %>
    <%= link_to "Transactions", spot_path(spot_index_filter_params.merge("view" => "transactions")), class: "border-b-2 px-4 py-2 text-sm font-medium #{@view == 'transactions' ? 'border-slate-800 text-slate-900' : 'border-transparent text-slate-500 hover:border-slate-300 hover:text-slate-700'}", **(@view == 'transactions' ? { 'aria-current': 'page' } : {}) %>
  </nav>

  <% if @view == "portfolio" %>
  <div class="mb-6 flex flex-wrap items-center gap-3" data-controller="dialog" data-dialog-open-on-connect-value="<%= @open_new_transaction_modal.present? %>">
    <button type="button" data-action="click->dialog#open" aria-label="New transaction" class="rounded-md bg-slate-800 px-4 py-2 text-sm font-medium text-white hover:bg-slate-700 focus:outline-none focus:ring-2 focus:ring-slate-500">
      New transaction
    </button>
    <dialog data-dialog-target="dialog" class="rounded-lg border border-slate-200 bg-white p-6 shadow-xl backdrop:bg-slate-900/20">
      <h2 class="mb-4 text-lg font-semibold text-slate-900">New transaction</h2>
      <%= form_with url: spot_transactions_path, method: :post, local: true, data: { turbo: false } do |f| %>
        <div class="space-y-4">
          <div data-controller="spot-token-select" data-spot-token-select-tokens-value="<%= @tokens_for_select.to_json %>">
            <%= f.label :token, "Token", class: "block text-sm font-medium text-slate-700" %>
            <%= f.text_field :token, value: @spot_transaction&.token, placeholder: "Search or type...", autocomplete: "off", class: "w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500", data: { spot_token_select_target: "input", action: "input->spot-token-select#filter keydown->spot-token-select#keydown" } %>
            <% if @spot_transaction&.errors&.key?(:token) %>
              <p class="mt-1 text-sm text-red-600"><%= @spot_transaction.errors[:token].first %></p>
            <% end %>
            <ul id="spot-token-listbox" data-spot-token-select-target="listbox" data-action="click->spot-token-select#selectOption" class="max-h-48 overflow-y-auto rounded-md border border-slate-200 bg-white shadow-lg" aria-label="Token suggestions"></ul>
          </div>
          <div>
            <%= f.label :side, "Side", class: "block text-sm font-medium text-slate-700" %>
            <%= f.select :side, options_for_select([["Buy", "buy"], ["Sell", "sell"]], @spot_transaction&.side), { include_blank: "Select" }, class: "w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
            <% if @spot_transaction&.errors&.key?(:side) %>
              <p class="mt-1 text-sm text-red-600"><%= @spot_transaction.errors[:side].first %></p>
            <% end %>
          </div>
          <div>
            <%= f.label :amount, "Amount", class: "block text-sm font-medium text-slate-700" %>
            <%= f.number_field :amount, value: @spot_transaction&.amount, step: :any, min: 0, placeholder: "0", class: "w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
            <% if @spot_transaction&.errors&.key?(:amount) %>
              <p class="mt-1 text-sm text-red-600"><%= @spot_transaction.errors[:amount].first %></p>
            <% end %>
          </div>
          <div>
            <%= f.label :price_usd, "Price (USD)", class: "block text-sm font-medium text-slate-700" %>
            <%= f.number_field :price_usd, value: @spot_transaction&.price_usd, step: :any, min: 0, placeholder: "0", class: "w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
            <% if @spot_transaction&.errors&.key?(:price_usd) %>
              <p class="mt-1 text-sm text-red-600"><%= @spot_transaction.errors[:price_usd].first %></p>
            <% end %>
          </div>
          <div>
            <%= f.label :executed_at, "Date & time", class: "block text-sm font-medium text-slate-700" %>
            <%= f.datetime_local_field :executed_at, value: @spot_transaction&.executed_at&.strftime("%Y-%m-%dT%H:%M"), class: "w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
            <p class="mt-1 text-xs text-slate-500">Interpreted in <%= Time.zone.name %> and stored in UTC.</p>
            <% if @spot_transaction&.errors&.key?(:executed_at) %>
              <p class="mt-1 text-sm text-red-600"><%= @spot_transaction.errors[:executed_at].first %></p>
            <% end %>
          </div>
        </div>
        <div class="mt-6 flex gap-2">
          <%= f.submit "Add transaction", class: "rounded-md bg-slate-800 px-4 py-2 text-sm font-medium text-white hover:bg-slate-700 focus:outline-none focus:ring-2 focus:ring-slate-500" %>
          <button type="button" data-action="dialog#close" class="rounded-md border border-slate-300 bg-white px-4 py-2 text-sm text-slate-700 hover:bg-slate-50">Cancel</button>
        </div>
      <% end %>
    </dialog>
  </div>

  <div class="mb-6">
    <%= form_with url: spot_import_path, method: :post, local: true, multipart: true, class: "flex flex-wrap items-end gap-3", data: { turbo: false } do |f| %>
      <%= f.file_field :csv_file, accept: "text/csv,application/csv,.csv", class: "rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
      <%= f.submit "Import CSV", class: "rounded-md bg-slate-800 px-4 py-2 text-sm font-medium text-white hover:bg-slate-700 focus:outline-none focus:ring-2 focus:ring-slate-500" %>
    <% end %>
    <p class="mt-2 text-sm text-slate-500">CSV columns: Date (UTC-3:00), Token, Type, Price (USD), Amount, Total value (USD), Fee, Fee Currency, Notes. Re-uploading the same file skips duplicates.</p>
  </div>

  <% if @positions.any? %>
    <div class="overflow-x-auto rounded-lg border border-slate-200 bg-white shadow-sm">
      <table class="min-w-full divide-y divide-slate-200">
        <thead class="bg-slate-50">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-slate-600">Token</th>
            <th scope="col" class="px-6 py-3 text-right text-xs font-medium uppercase tracking-wider text-slate-600">Avg buy price</th>
            <th scope="col" class="px-6 py-3 text-right text-xs font-medium uppercase tracking-wider text-slate-600">Current qty</th>
            <th scope="col" class="px-6 py-3 text-right text-xs font-medium uppercase tracking-wider text-slate-600">Current price</th>
            <th scope="col" class="px-6 py-3 text-right text-xs font-medium uppercase tracking-wider text-slate-600">Current net value</th>
            <th scope="col" class="px-6 py-3 text-right text-xs font-medium uppercase tracking-wider text-slate-600">Unrealized PnL</th>
            <th scope="col" class="px-6 py-3 text-right text-xs font-medium uppercase tracking-wider text-slate-600">Unrealized ROI</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-slate-600">Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-200 bg-white">
          <% @positions.each do |pos| %>
            <% current_price = @current_prices[pos.token] %>
            <% unrealized = pos.open? && current_price ? (current_price - pos.breakeven.to_d) * pos.balance : nil %>
            <% current_net_value = pos.open? && current_price ? (current_price.to_d * pos.balance) : nil %>
            <% unrealized_roi = unrealized && pos.net_usd_invested.to_d.positive? ? (unrealized / pos.net_usd_invested.to_d * 100) : nil %>
            <tr>
              <td class="whitespace-nowrap px-6 py-4 text-sm font-medium text-slate-900"><%= pos.token %></td>
              <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-700"><%= pos.breakeven ? format_money(pos.breakeven) : "—" %></td>
              <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-700"><%= number_with_delimiter(pos.balance, delimiter: ",", precision: 8) %></td>
              <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-700"><%= current_price ? format_money(current_price) : "—" %></td>
              <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-700"><%= current_net_value ? format_money(current_net_value) : "—" %></td>
              <td class="whitespace-nowrap px-6 py-4 text-right text-sm <%= unrealized.nil? ? 'text-slate-500' : (unrealized >= 0 ? 'text-emerald-600' : 'text-red-600') %>"><%= unrealized.nil? ? "—" : format_money(unrealized) %></td>
              <td class="whitespace-nowrap px-6 py-4 text-right text-sm <%= unrealized_roi.nil? ? 'text-slate-500' : (unrealized_roi >= 0 ? 'text-emerald-600' : 'text-red-600') %>"><%= unrealized_roi.nil? ? "—" : number_to_percentage(unrealized_roi, precision: 2) %></td>
              <td class="whitespace-nowrap px-6 py-4 text-sm text-slate-600"><%= pos.open? ? "Open" : "Closed" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <% if current_user.exchange_accounts.empty? %>
      <p class="mt-4 text-sm text-slate-500">Connect an <%= link_to "exchange account", exchange_accounts_path, class: "text-slate-700 underline" %> to see live prices, current net value, and unrealized PnL/ROI.</p>
    <% end %>
  <% else %>
    <p class="text-slate-600">No spot positions yet. Upload a transaction history CSV above to get started.</p>
  <% end %>
  <% end %>

  <% if @view == "transactions" %>
    <%= form_with url: spot_path, method: :get, local: true, class: "mb-4 flex flex-wrap items-end gap-3", data: { turbo: false } do |f| %>
      <%= f.hidden_field :view, value: "transactions" %>
      <%= f.label :from_date, "From", class: "text-sm font-medium text-slate-700" %>
      <%= f.date_field :from_date, value: @from_date, class: "rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
      <%= f.label :to_date, "To", class: "text-sm font-medium text-slate-700" %>
      <%= f.date_field :to_date, value: @to_date, class: "rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
      <%= f.label :token, "Token", class: "text-sm font-medium text-slate-700" %>
      <%= f.select :token, options_for_select([["All", ""]] + (@tokens_for_filter || []).map { |t| [t, t] }, @filter_token), {}, { class: "rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" } %>
      <%= f.label :side, "Side", class: "text-sm font-medium text-slate-700" %>
      <%= f.select :side, options_for_select([["All", ""], ["Buy", "buy"], ["Sell", "sell"]], @filter_side), {}, { class: "rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" } %>
      <%= f.submit "Filter", class: "rounded-md bg-slate-800 px-3 py-2 text-sm font-medium text-white hover:bg-slate-700 focus:outline-none focus:ring-2 focus:ring-slate-500" %>
    <% end %>

    <% if @transactions.present? %>
      <div class="overflow-x-auto rounded-lg border border-slate-200 bg-white shadow-sm">
        <table class="min-w-full divide-y divide-slate-200">
          <thead class="bg-slate-50">
            <tr>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-slate-600">Date / time</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-slate-600">Token</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-slate-600">Side</th>
              <th scope="col" class="px-6 py-3 text-right text-xs font-medium uppercase tracking-wider text-slate-600">Amount</th>
              <th scope="col" class="px-6 py-3 text-right text-xs font-medium uppercase tracking-wider text-slate-600">Price (USD)</th>
              <th scope="col" class="px-6 py-3 text-right text-xs font-medium uppercase tracking-wider text-slate-600">Total value (USD)</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-200 bg-white">
            <% @transactions.each do |tx| %>
              <tr>
                <td class="whitespace-nowrap px-6 py-4 text-sm text-slate-700"><%= tx.executed_at.strftime("%b %d, %Y %H:%M") %></td>
                <td class="whitespace-nowrap px-6 py-4 text-sm font-medium text-slate-900"><%= tx.token %></td>
                <td class="whitespace-nowrap px-6 py-4 text-sm text-slate-700 capitalize"><%= tx.side %></td>
                <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-700"><%= number_with_delimiter(tx.amount, delimiter: ",", precision: 8) %></td>
                <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-700"><%= format_money(tx.price_usd) %></td>
                <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-700"><%= format_money(tx.total_value_usd) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <% if @pagy.last > 1 %>
        <div class="mt-4 flex justify-center">
          <%== @pagy.series_nav %>
        </div>
      <% end %>
    <% else %>
      <div class="rounded-lg border border-slate-200 bg-white p-12 text-center text-slate-600">
        <p>No spot transactions yet.</p>
      </div>
    <% end %>
  <% end %>
</div>
