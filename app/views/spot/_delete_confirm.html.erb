<%= turbo_frame_tag "spot-transaction-delete-frame" do %>
  <h2 class="mb-4 text-lg font-semibold text-slate-900"><%= t("spot.delete_confirm.title") %></h2>

  <p class="mb-6 text-sm text-slate-600">
    <%= t("spot.delete_confirm.confirm_message",
          token_side: "#{transaction.token} #{transaction.side.capitalize}",
          amount: number_with_delimiter(transaction.amount, delimiter: ","),
          date: transaction.executed_at.strftime("%b %d, %Y")) %>
    <% unless transaction.side.in?(%w[deposit withdraw]) %> <%= t("spot.delete_confirm.at_price", price: format_money(transaction.price_usd)) %><% end %>?
    <br><span class="font-medium text-red-600"><%= t("spot.delete_confirm.cannot_undo") %></span>
  </p>

  <div class="flex gap-2">
    <%= button_to t("spot.delete_confirm.confirm"), destroy_spot_transaction_path(transaction), method: :delete,
        class: "rounded-md bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-500" %>
    <button type="button" data-action="click->turbo-modal#close"
        class="rounded-md border border-slate-300 bg-white px-4 py-2 text-sm text-slate-700 hover:bg-slate-50">
      <%= t("spot.delete_confirm.cancel") %>
    </button>
  </div>
<% end %>
