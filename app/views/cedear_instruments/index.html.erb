<div>
  <div class="mb-6 flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-semibold text-slate-900">CEDEAR instruments</h1>
      <p class="mt-1 text-sm text-slate-500">Manage the CEDEAR tickers you trade, including their ratio to the underlying US stock.</p>
    </div>
    <%= render ButtonComponent.new(label: "Add instrument", href: new_cedear_instrument_path) %>
  </div>

  <section class="rounded-lg border border-slate-200 bg-white shadow-sm">
    <% if @cedear_instruments.any? %>
      <%= render DataTableComponent.new(columns: [
        { label: "Ticker (CEDEAR)", classes: "text-left" },
        { label: "Ratio", classes: "text-right" },
        { label: "Underlying", classes: "text-left" },
        { label: "", classes: "text-right" }
      ]) do |table| %>
        <% @cedear_instruments.each do |instrument| %>
          <% table.with_row do %>
            <td class="whitespace-nowrap px-6 py-4 text-sm font-semibold text-slate-900"><%= instrument.ticker %></td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-700">
              <%= number_with_precision(instrument.ratio, precision: 4, strip_insignificant_zeros: true) %>:1
            </td>
            <td class="whitespace-nowrap px-6 py-4 text-sm text-slate-500"><%= instrument.underlying_ticker.presence || "—" %></td>
            <td class="whitespace-nowrap px-6 py-4 text-right text-sm">
              <%= link_to "Edit", edit_cedear_instrument_path(instrument), class: "mr-4 text-slate-600 hover:text-slate-900" %>
              <%= button_to "Remove", cedear_instrument_path(instrument), method: :delete,
                    data: { turbo_confirm: "Remove #{instrument.ticker}?" },
                    class: "text-red-600 hover:text-red-800 bg-transparent border-0 p-0 cursor-pointer text-sm" %>
            </td>
          <% end %>
        <% end %>
      <% end %>
    <% else %>
      <%= render EmptyStateComponent.new(message: "No CEDEAR instruments yet. Add one to enable ratio auto-fill in Argentina-mode trade forms.") %>
    <% end %>
  </section>
</div>
