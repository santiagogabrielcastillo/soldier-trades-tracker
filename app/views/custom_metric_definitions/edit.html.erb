<div class="mx-auto max-w-lg">
  <%= render BreadcrumbComponent.new(items: [
    { label: "Companies", url: companies_path },
    { label: @company.ticker, url: company_path(@company) },
    { label: "Edit metric", url: nil }
  ]) %>
  <div class="mb-6">
    <h1 class="text-2xl font-semibold text-slate-900">Edit <%= @definition.name %></h1>
  </div>

  <%= render ErrorSummaryComponent.new(model: @definition) %>

  <%= form_with model: [@company, @definition], local: true, class: "space-y-4 rounded-lg border border-slate-200 bg-white p-6 shadow-sm" do |f| %>
    <div>
      <%= f.label :name, "Metric name", class: "block text-sm font-medium text-slate-700" %>
      <%= f.text_field :name, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
    </div>
    <div>
      <%= f.label :data_type, "Type", class: "block text-sm font-medium text-slate-700" %>
      <%= f.select :data_type,
            options_for_select([["Number", "number"], ["Money", "money"], ["Percentage", "percentage"], ["Text", "text"]], @definition.data_type),
            {},
            { class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" } %>
    </div>
    <div class="flex gap-3 pt-2">
      <%= f.submit "Save", class: "rounded-md bg-slate-800 px-4 py-2 text-sm font-medium text-white hover:bg-slate-700 focus:outline-none focus:ring-2 focus:ring-slate-500 focus:ring-offset-2" %>
      <%= link_to "Cancel", company_path(@company), class: "rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50" %>
    </div>
  <% end %>
</div>
