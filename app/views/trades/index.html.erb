<div>
  <h1 class="mb-4 text-2xl font-semibold text-slate-900">Trades</h1>

  <nav class="mb-6 flex gap-1 border-b border-slate-200" aria-label="Tabs">
    <%= link_to "History", trades_path(view: "history"), class: "border-b-2 px-4 py-2 text-sm font-medium #{@view == 'history' ? 'border-slate-800 text-slate-900' : 'border-transparent text-slate-500 hover:border-slate-300 hover:text-slate-700'}" %>
    <%= link_to "Portfolio", trades_path(view: "portfolio"), class: "border-b-2 px-4 py-2 text-sm font-medium #{@view == 'portfolio' ? 'border-slate-800 text-slate-900' : 'border-transparent text-slate-500 hover:border-slate-300 hover:text-slate-700'}" %>
  </nav>

  <% if @view == "portfolio" && @portfolios.present? %>
    <div class="mb-4 flex items-center gap-3">
      <label for="portfolio_id" class="text-sm font-medium text-slate-700">Portfolio</label>
      <%= form_with url: trades_path, method: :get, local: true, class: "flex items-center gap-2", data: { turbo: false } do |f| %>
        <%= f.hidden_field :view, value: "portfolio" %>
        <%= f.select :portfolio_id, options_from_collection_for_select(@portfolios, :id, :name, @portfolio&.id), { include_blank: "Select a portfolio" }, { class: "rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500", id: "portfolio_id", onchange: "this.form.submit()" } %>
      <% end %>
      <% if @portfolio %>
        <span class="text-sm text-slate-500"><%= @portfolio.date_range_label %><% if @portfolio.initial_balance != 0 %> · Floor <%= format_money(@portfolio.initial_balance) %><% end %></span>
      <% end %>
    </div>
  <% end %>

  <% if @positions.any? %>
    <% visible_ids = @visible_column_ids || TradesIndexColumns::DEFAULT_VISIBLE %>
    <div class="mb-2 flex items-center justify-end" data-controller="dialog">
      <button type="button" data-action="dialog#open" aria-label="Choose columns" class="rounded-md border border-slate-300 bg-white px-3 py-1.5 text-sm text-slate-700 hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-slate-500">
        Columns
      </button>
      <dialog data-dialog-target="dialog" class="rounded-lg border border-slate-200 bg-white p-6 shadow-xl backdrop:bg-slate-900/20">
        <h2 class="mb-4 text-lg font-semibold text-slate-900">Visible columns</h2>
        <%= form_with url: user_preferences_trades_index_columns_path, method: :patch, local: true, data: { turbo: false } do |f| %>
          <%= f.hidden_field :view, value: @view %>
          <%= f.hidden_field :portfolio_id, value: @portfolio&.id %>
          <div class="grid grid-cols-2 gap-2">
            <% TradesIndexColumns::ALL_IDS.each do |col_id| %>
              <label class="flex items-center gap-2 text-sm">
                <%= f.check_box :column_ids, { multiple: true, checked: visible_ids.include?(col_id) }, col_id, nil %>
                <%= TradesIndexColumns::LABELS[col_id] %>
              </label>
            <% end %>
          </div>
          <div class="mt-4 flex gap-2">
            <%= f.submit "Save", class: "rounded-md bg-slate-800 px-4 py-2 text-sm font-medium text-white hover:bg-slate-700 focus:outline-none focus:ring-2 focus:ring-slate-500" %>
            <button type="button" data-action="dialog#close" class="rounded-md border border-slate-300 bg-white px-4 py-2 text-sm text-slate-700 hover:bg-slate-50">Cancel</button>
          </div>
        <% end %>
      </dialog>
    </div>
    <div class="overflow-y-hidden overflow-x-auto rounded-lg border border-slate-200 bg-white shadow-sm">
      <table class="min-w-full divide-y divide-slate-200">
        <thead class="bg-slate-50">
          <tr>
            <% visible_ids.each do |col_id| %>
              <th scope="col" class="<%= col_id.in?(%w[margin_used roi commission net_pl balance entry_price exit_price]) ? 'text-right' : 'text-left' %> px-6 py-3 text-xs font-medium uppercase tracking-wider text-slate-600"><%= TradesIndexColumns::LABELS[col_id] %></th>
            <% end %>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-200 bg-white">
          <% @positions.each do |pos| %>
            <% roi_val = pos.open? ? pos.unrealized_roi_percent(@current_prices[pos.symbol]) : pos.roi_percent %>
            <% pnl_val = pos.open? ? pos.unrealized_pnl(@current_prices[pos.symbol]) : pos.net_pl %>
            <tr>
              <% visible_ids.each do |col_id| %>
                <td class="<%= trades_index_cell_css(pos, col_id, roi_val: roi_val, pnl_val: pnl_val) %>">
                  <%= trades_index_cell_content(pos, col_id, roi_val: roi_val, pnl_val: pnl_val) %>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <% if @pagy.last > 1 %>
      <div class="mt-4 flex justify-center">
          <%== @pagy.series_nav %>
        </div>
    <% end %>
  <% else %>
    <div class="rounded-lg border border-slate-200 bg-white p-12 text-center text-slate-600">
      <% if @view == "portfolio" && @portfolio %>
        <p>No trades in this portfolio's date range.</p>
      <% else %>
        <p>No trades yet. Link an exchange account and sync will run on your schedule.</p>
      <% end %>
    </div>
  <% end %>
</div>
