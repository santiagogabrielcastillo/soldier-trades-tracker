<div>
  <%= render PageHeaderComponent.new(title: "Trades") do |c| %>
    <% c.with_actions do %>
      <%= link_to "Manage portfolios", portfolios_path, class: "rounded-md border border-slate-300 bg-white px-3 py-1.5 text-sm text-slate-700 hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-slate-500" %>
      <% if @exchange_accounts.size == 1 %>
        <%= link_to "Add manual trade", new_exchange_account_manual_trade_path(@exchange_accounts.first), class: "rounded-md border border-slate-300 bg-white px-3 py-1.5 text-sm text-slate-700 hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-slate-500" %>
      <% elsif @exchange_accounts.size > 1 %>
        <details class="relative">
          <summary class="cursor-pointer list-none rounded-md border border-slate-300 bg-white px-3 py-1.5 text-sm text-slate-700 hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-slate-500">Add manual trade ▾</summary>
          <div class="absolute right-0 top-full z-10 mt-1 w-52 rounded-md border border-slate-200 bg-white py-1 shadow-lg">
            <% @exchange_accounts.each do |acct| %>
              <%= link_to acct.provider_type.to_s.capitalize, new_exchange_account_manual_trade_path(acct),
                    class: "block px-4 py-2 text-sm text-slate-700 hover:bg-slate-50" %>
            <% end %>
          </div>
        </details>
      <% end %>
    <% end %>
  <% end %>

  <nav class="mb-6 flex gap-1 border-b border-slate-200" aria-label="Tabs">
    <%= link_to "History", trades_path(trades_index_filter_params.merge("view" => "history")), class: "border-b-2 px-4 py-2 text-sm font-medium #{@view == 'history' ? 'border-slate-800 text-slate-900' : 'border-transparent text-slate-500 hover:border-slate-300 hover:text-slate-700'}" %>
    <% (@exchange_accounts || []).each do |account| %>
      <%= link_to account.provider_type.to_s.capitalize, trades_path(trades_index_filter_params.merge("view" => "exchange", "exchange_account_id" => account.id)), class: "border-b-2 px-4 py-2 text-sm font-medium #{@view == 'exchange' && @exchange_account&.id == account.id ? 'border-slate-800 text-slate-900' : 'border-transparent text-slate-500 hover:border-slate-300 hover:text-slate-700'}" %>
    <% end %>
    <%= link_to "Portfolio", trades_path(trades_index_filter_params.merge("view" => "portfolio", "portfolio_id" => @portfolio&.id)), class: "border-b-2 px-4 py-2 text-sm font-medium #{@view == 'portfolio' ? 'border-slate-800 text-slate-900' : 'border-transparent text-slate-500 hover:border-slate-300 hover:text-slate-700'}" %>
  </nav>

  <% if @view == "history" %>
    <%= render DateRangeFilterComponent.new(
          url: trades_path,
          from: @from_date,
          to: @to_date,
          extra_params: { view: "history" },
          clear_url: trades_path(view: "history")
        ) do |c| %>
      <% c.with_extra_fields do %>
        <div class="flex flex-col gap-1">
          <label for="exchange_account_id" class="text-sm font-medium text-slate-700">Exchange</label>
          <%= select_tag :exchange_account_id,
                options_for_select([["All exchanges", nil]] + (@exchange_accounts || []).map { |a| [a.provider_type.to_s.capitalize, a.id] }, params[:exchange_account_id]),
                class: "rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500 w-auto min-w-[8rem]",
                data: { auto_submit_form_target: "trigger" } %>
        </div>
      <% end %>
    <% end %>
  <% end %>

  <% if @view == "exchange" %>
    <%= render DateRangeFilterComponent.new(
          url: trades_path,
          from: @from_date,
          to: @to_date,
          extra_params: { view: "exchange", exchange_account_id: @exchange_account&.id },
          clear_url: trades_path(view: "exchange", exchange_account_id: @exchange_account&.id)
        ) %>
  <% end %>

  <% if @view == "portfolio" && @portfolios.present? %>
    <div class="mb-4 flex items-center gap-3">
      <label for="portfolio_id" class="text-sm font-medium text-slate-700">Portfolio</label>
      <%= form_with url: trades_path, method: :get, local: true, class: "flex items-center gap-2", data: { turbo: false } do |f| %>
        <%= f.hidden_field :view, value: "portfolio" %>
        <%= f.select :portfolio_id, options_from_collection_for_select(@portfolios, :id, :name, @portfolio&.id), { include_blank: "Select a portfolio" }, { class: "rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500", id: "portfolio_id", onchange: "this.form.submit()" } %>
      <% end %>
      <% if @portfolio %>
        <span class="text-sm text-slate-500"><%= @portfolio.date_range_label %><% if @portfolio.exchange_account.present? %> · <%= @portfolio.exchange_account.provider_type.to_s.capitalize %> only<% end %><% if @portfolio.initial_balance != 0 %> · Floor <%= format_money(@portfolio.initial_balance) %><% end %></span>
      <% end %>
    </div>
  <% end %>

  <% if @positions.any? %>
    <% visible_ids = @visible_column_ids || TradesIndexColumns::DEFAULT_VISIBLE %>
    <div class="mb-2 flex items-center justify-end" data-controller="dialog">
      <button type="button" data-action="dialog#open" aria-label="Choose columns" class="rounded-md border border-slate-300 bg-white px-3 py-1.5 text-sm text-slate-700 hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-slate-500">
        Columns
      </button>
      <dialog data-dialog-target="dialog" class="rounded-lg border border-slate-200 bg-white p-6 shadow-xl backdrop:bg-slate-900/20">
        <h2 class="mb-4 text-lg font-semibold text-slate-900">Visible columns</h2>
        <%= form_with url: user_preferences_trades_index_columns_path, method: :patch, local: true, data: { turbo: false } do |f| %>
          <%= f.hidden_field :view, value: @view %>
          <%= f.hidden_field :portfolio_id, value: @portfolio&.id %>
          <%= f.hidden_field :exchange_account_id, value: @exchange_account&.id %>
          <%= f.hidden_field :from_date, value: @from_date %>
          <%= f.hidden_field :to_date, value: @to_date %>
          <div class="grid grid-cols-2 gap-2">
            <% TradesIndexColumns::ALL_IDS.each do |col_id| %>
              <label class="flex items-center gap-2 text-sm">
                <%= f.check_box :column_ids, { multiple: true, checked: visible_ids.include?(col_id) }, col_id, nil %>
                <%= TradesIndexColumns::LABELS[col_id] %>
              </label>
            <% end %>
          </div>
          <div class="mt-4 flex gap-2">
            <%= f.submit "Save", class: "rounded-md bg-slate-800 px-4 py-2 text-sm font-medium text-white hover:bg-slate-700 focus:outline-none focus:ring-2 focus:ring-slate-500" %>
            <button type="button" data-action="dialog#close" class="rounded-md border border-slate-300 bg-white px-4 py-2 text-sm text-slate-700 hover:bg-slate-50">Cancel</button>
          </div>
        <% end %>
      </dialog>
    </div>
    <div class="overflow-y-hidden overflow-x-auto rounded-lg border border-slate-200 bg-white shadow-sm">
      <table class="min-w-full divide-y divide-slate-200">
        <thead class="bg-slate-50">
          <tr>
            <% visible_ids.each do |col_id| %>
              <th scope="col" class="<%= col_id.in?(%w[margin_used roi commission net_pl balance entry_price exit_price]) ? 'text-right' : 'text-left' %> px-6 py-3 text-xs font-medium uppercase tracking-wider text-slate-600"><%= TradesIndexColumns::LABELS[col_id] %></th>
            <% end %>
            <th scope="col" class="px-4 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-200 bg-white">
          <% @positions.each do |pos| %>
            <% open_flag = pos.open? %>
            <% roi_val = open_flag ? pos.unrealized_roi_percent(@current_prices[pos.symbol]) : pos.roi_percent %>
            <% pnl_val = open_flag ? pos.unrealized_pnl(@current_prices[pos.symbol]) : pos.net_pl %>
            <% memoized = { open: open_flag, entry_price: pos.entry_price, exit_price: pos.exit_price, open_quantity: pos.open_quantity, closed_quantity: pos.closed_quantity, position_side: pos.position_side, total_commission: pos.total_commission, margin_used: pos.margin_used } %>
            <tr>
              <% visible_ids.each do |col_id| %>
                <td class="<%= trades_index_cell_css(pos, col_id, roi_val: roi_val, pnl_val: pnl_val, memoized: memoized) %>">
                  <%= trades_index_cell_content(pos, col_id, roi_val: roi_val, pnl_val: pnl_val, memoized: memoized) %>
                </td>
              <% end %>
              <td class="px-4 py-3 text-right text-sm whitespace-nowrap">
                <% pos.trades.select(&:manual?).each do |t| %>
                  <%= link_to "Edit",
                      edit_exchange_account_manual_trade_path(t.exchange_account, t),
                      class: "mr-2 text-slate-500 hover:text-slate-800 text-xs" %>
                  <%= button_to "Delete",
                      exchange_account_manual_trade_path(t.exchange_account, t),
                      method: :delete,
                      data: { turbo_confirm: "Delete this manual trade and rebuild positions?" },
                      class: "text-red-500 hover:text-red-700 text-xs bg-transparent border-0 p-0 cursor-pointer" %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <% if @pagy.last > 1 %>
      <div class="mt-4 flex justify-center">
        <%== @pagy.series_nav %>
      </div>
    <% end %>
  <% else %>
    <% if @view == "portfolio" && @portfolio %>
      <%= render EmptyStateComponent.new(message: "No trades in this portfolio's date range.") %>
    <% elsif @view == "exchange" %>
      <%= render EmptyStateComponent.new(message: "No trades for this exchange.") do %>
        <p class="text-sm"><%= link_to "Sync now", exchange_accounts_path, class: "text-slate-800 underline hover:no-underline" %> or link another account.</p>
      <% end %>
    <% else %>
      <%= render EmptyStateComponent.new(message: "No trades yet. Link an exchange account and sync will run on your schedule.") %>
    <% end %>
  <% end %>
</div>
