<div class="mx-auto max-w-4xl">
  <%= render BreadcrumbComponent.new(items: [
    { label: t("companies.index.title"), url: companies_path },
    { label: @company.ticker, url: company_path(@company) },
    { label: t("companies.edit.breadcrumb"), url: nil }
  ]) %>
  <div class="mb-6">
    <h1 class="text-2xl font-semibold text-slate-900"><%= t("companies.edit.title", ticker: @company.ticker) %></h1>
  </div>
  <%= render "form" %>
</div>
