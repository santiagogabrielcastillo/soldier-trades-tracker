<div class="mx-auto max-w-4xl">
  <h1 class="mb-2 text-2xl font-semibold text-slate-900">Edit account settings</h1>
  <p class="mb-6 text-sm text-slate-600">Configure which quote currencies are synced for this <span class="font-medium capitalize"><%= @exchange_account.provider_type %></span> account.</p>

  <%= form_with model: @exchange_account, url: exchange_account_path(@exchange_account), method: :patch, local: true, class: "space-y-6", data: { turbo: false } do |f| %>
    <%= render ErrorSummaryComponent.new(model: @exchange_account) %>

    <div>
      <p class="block text-sm font-medium text-slate-700 mb-3">Quote currencies to sync</p>
      <% ExchangeAccount::SUPPORTED_QUOTE_CURRENCIES.each do |currency| %>
        <label class="flex items-center gap-3 mb-2 cursor-pointer">
          <%= check_box_tag "exchange_account[allowed_quote_currencies][]",
                currency,
                @exchange_account.allowed_quote_currencies.include?(currency),
                id: "currency_#{currency.downcase}",
                class: "h-4 w-4 rounded border-slate-300 text-slate-800 focus:ring-slate-500" %>
          <span class="text-sm text-slate-700"><%= currency %></span>
        </label>
      <% end %>
      <%# Hidden field ensures an empty submission (all unchecked) is caught by validation %>
      <%= hidden_field_tag "exchange_account[allowed_quote_currencies][]", "" %>
    </div>

    <div class="flex gap-3 pt-2">
      <%= f.submit "Save settings", class: "rounded-md bg-slate-800 px-4 py-2 text-sm font-medium text-white hover:bg-slate-700 focus:outline-none focus:ring-2 focus:ring-slate-500 focus:ring-offset-2" %>
      <%= link_to "Cancel", exchange_accounts_path, class: "rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50" %>
    </div>
  <% end %>
</div>
