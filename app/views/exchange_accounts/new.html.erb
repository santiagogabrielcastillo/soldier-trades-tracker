<div class="mx-auto max-w-4xl">
  <h1 class="mb-2 text-2xl font-semibold text-slate-900"><%= t("exchange_accounts.new.title") %></h1>
  <p class="mb-6 text-sm text-slate-600">Link your exchange account using an API key. Create one under your exchange (BingX → User Center → API Management; Binance Futures → API Management). Only perpetual futures trades are synced.</p>

  <%= form_with model: @exchange_account, url: exchange_accounts_path, local: true, class: "space-y-4", data: { turbo: false } do |f| %>
    <%= render ErrorSummaryComponent.new(model: @exchange_account) %>

    <div>
      <%= f.label :provider_type, t("exchange_accounts.new.exchange"), class: "block text-sm font-medium text-slate-700" %>
      <%= f.select :provider_type, [["BingX (Perpetual futures)", "bingx"], ["Binance (USDⓈ-M Futures)", "binance"]], {}, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
    </div>

    <%= render FormFieldComponent.new(form: f, attribute: :api_key, label: t("exchange_accounts.new.api_key"), autocomplete: "off", placeholder: "Your API key") %>
    <%= render FormFieldComponent.new(form: f, attribute: :api_secret, label: t("exchange_accounts.new.api_secret"), type: :password, autocomplete: "off", placeholder: "Your API secret") %>

    <div class="flex gap-3 pt-2">
      <%= f.submit t("exchange_accounts.new.submit"), class: "rounded-md bg-slate-800 px-4 py-2 text-sm font-medium text-white hover:bg-slate-700 focus:outline-none focus:ring-2 focus:ring-slate-500 focus:ring-offset-2" %>
      <%= link_to t("exchange_accounts.new.cancel"), exchange_accounts_path, class: "rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50" %>
    </div>
  <% end %>
</div>
