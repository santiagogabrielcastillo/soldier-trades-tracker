<div class="mx-auto max-w-lg">
  <h1 class="mb-2 text-2xl font-semibold text-slate-900">Link exchange account</h1>
  <p class="mb-6 text-sm text-slate-600">Use read-only API keys only. Keys with Trade or Withdraw permissions will be rejected.</p>

  <%= form_with model: @exchange_account, url: exchange_accounts_path, local: true, class: "space-y-4" do |f| %>
    <% if @exchange_account.errors.any? %>
      <div class="rounded-md bg-amber-50 p-4 text-sm text-amber-800">
        <ul class="list-disc pl-5">
          <% @exchange_account.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :provider_type, "Exchange", class: "block text-sm font-medium text-slate-700" %>
      <%= f.select :provider_type, ExchangeAccount::PROVIDER_TYPES.map { |p| [p.titleize, p] }, { prompt: "Select exchange" }, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
    </div>

    <div>
      <%= f.label :api_key, "API Key", class: "block text-sm font-medium text-slate-700" %>
      <%= f.text_field :api_key, autocomplete: "off", class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500", placeholder: "Your read-only API key" %>
    </div>

    <div>
      <%= f.label :api_secret, "API Secret", class: "block text-sm font-medium text-slate-700" %>
      <%= f.password_field :api_secret, autocomplete: "off", class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500", placeholder: "Your API secret" %>
    </div>

    <div class="flex gap-3 pt-2">
      <%= f.submit "Link account", class: "rounded-md bg-slate-800 px-4 py-2 text-sm font-medium text-white hover:bg-slate-700 focus:outline-none focus:ring-2 focus:ring-slate-500 focus:ring-offset-2" %>
      <%= link_to "Cancel", exchange_accounts_path, class: "rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50" %>
    </div>
  <% end %>
</div>
