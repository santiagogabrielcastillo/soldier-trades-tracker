<div>
  <div class="mb-6 flex items-center justify-between">
    <h1 class="text-2xl font-semibold text-slate-900">Exchange accounts</h1>
    <%= render ButtonComponent.new(label: "Link account", href: new_exchange_account_path) %>
  </div>

  <section class="rounded-lg border border-slate-200 bg-white shadow-sm">
    <% if @exchange_accounts.any? %>
      <ul class="divide-y divide-slate-200">
        <% @exchange_accounts.each do |account| %>
          <li class="flex items-center justify-between px-6 py-4">
            <div>
              <div class="flex items-center gap-2">
                <span class="font-medium capitalize text-slate-900"><%= account.provider_type %></span>
                <% sync_failed = account.last_sync_failed_at.present? && (account.last_synced_at.nil? || account.last_sync_failed_at > account.last_synced_at) %>
                <% if sync_failed %>
                  <span class="inline-flex items-center gap-1 rounded-full bg-red-50 px-2 py-0.5 text-xs font-medium text-red-700 ring-1 ring-inset ring-red-600/20" title="<%= account.last_sync_error %>">
                    ⚠ Sync failed
                  </span>
                <% end %>
              </div>
              <div class="mt-0.5 flex items-center gap-2 text-sm text-slate-500">
                <span>Linked <%= time_ago_in_words(account.linked_at || account.created_at) %> ago</span>
                <% if account.last_synced_at %>
                  <span class="text-slate-300">·</span>
                  <span>Last synced <%= time_ago_in_words(account.last_synced_at) %> ago</span>
                <% elsif account.created_at < 1.hour.ago %>
                  <span class="text-slate-300">·</span>
                  <span class="text-amber-600">Never synced</span>
                <% end %>
              </div>
              <div class="mt-1 flex items-center gap-1">
                <span class="text-xs text-slate-400">Syncing:</span>
                <% account.allowed_quote_currencies.each do |currency| %>
                  <span class="inline-flex items-center rounded-full bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-600"><%= currency %></span>
                <% end %>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <% provider_supported = Exchanges::ProviderForAccount.new(account).supported? %>
              <% if provider_supported && account.can_sync? %>
                <%= button_to "Sync now", sync_exchange_account_path(account), method: :post, class: "rounded-md border border-slate-300 bg-white px-3 py-1.5 text-sm text-slate-700 hover:bg-slate-50" %>
              <% elsif provider_supported && !account.can_sync? %>
                <span class="text-sm text-slate-400">Rate limit (2/day)</span>
              <% end %>
              <% if provider_supported && current_user.admin? %>
                <%= form_with url: historic_sync_exchange_account_path(account), method: :post, class: "flex items-center gap-1" do |f| %>
                  <%= f.text_field :extra_symbols, placeholder: "e.g. BTCUSDT,ETHUSDT", size: 22,
                        class: "rounded-md border border-slate-300 px-2 py-1 text-xs text-slate-700 placeholder-slate-400 focus:outline-none focus:ring-1 focus:ring-slate-400" %>
                  <%= f.submit "Historic sync",
                        class: "cursor-pointer rounded-md border border-slate-300 bg-white px-3 py-1.5 text-sm text-slate-700 hover:bg-slate-50",
                        data: { turbo_confirm: "Fetch all trades from 2018 onwards? This may take a few minutes." } %>
                <% end %>
              <% end %>
              <%= link_to "Add trade", new_exchange_account_manual_trade_path(account), class: "text-sm text-slate-600 hover:text-slate-900" %>
              <%= link_to "Settings", edit_exchange_account_path(account), class: "text-sm text-slate-600 hover:text-slate-900" %>
              <%= button_to "Remove", exchange_account_path(account), method: :delete, data: { turbo_confirm: "Remove this exchange account?" }, class: "text-sm text-slate-600 hover:text-red-600" %>
            </div>
          </li>
        <% end %>
      </ul>
      <% if @pagy.last > 1 %>
        <div class="flex justify-center border-t border-slate-200 px-6 py-4">
          <%== @pagy.series_nav %>
        </div>
      <% end %>
    <% else %>
      <div class="flex flex-col items-center gap-4 px-6 py-14 text-center">
        <div class="flex h-14 w-14 items-center justify-center rounded-full bg-slate-100">
          <svg class="h-7 w-7 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" />
          </svg>
        </div>
        <div>
          <p class="text-base font-medium text-slate-900">No exchange accounts linked yet</p>
          <p class="mt-1 text-sm text-slate-500">Connect Binance or BingX to start syncing your perpetual futures trades.</p>
        </div>
        <%= render ButtonComponent.new(label: "Link your first account", href: new_exchange_account_path) %>
      </div>
    <% end %>
  </section>
</div>
