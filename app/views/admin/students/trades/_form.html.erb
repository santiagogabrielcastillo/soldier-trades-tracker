<% field_classes = "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
<% label_classes = "block text-sm font-medium text-slate-700" %>

<%= form_with model: @trade, url: url, method: method, class: "space-y-4" do |f| %>
  <% if @trade.errors.any? %>
    <div class="rounded-md border border-red-200 bg-red-50 p-4">
      <p class="text-sm font-medium text-red-800"><%= pluralize(@trade.errors.count, "error") %> prevented this trade from being saved:</p>
      <ul class="mt-2 list-inside list-disc space-y-1 text-sm text-red-700">
        <% @trade.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
      </ul>
    </div>
  <% end %>

  <% if defined?(@exchange_accounts) && @exchange_accounts.any? && method == :post %>
    <div>
      <%= label_tag :exchange_account_id, "Exchange account", class: label_classes %>
      <%= select_tag :exchange_account_id,
            options_from_collection_for_select(@exchange_accounts, :id, :provider_type),
            class: field_classes %>
    </div>
  <% end %>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :symbol, "Symbol (e.g. BTC-USDT)", class: label_classes %>
      <%= f.text_field :symbol, required: true, class: field_classes %>
    </div>
    <div>
      <%= f.label :side, "Side", class: label_classes %>
      <%= f.select :side, options_for_select([["Buy", "buy"], ["Sell", "sell"]], @trade.side),
            { prompt: "Select" }, required: true, class: field_classes %>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :quantity, "Quantity", class: label_classes %>
      <%= f.number_field :quantity, required: true, step: "any", min: 0, class: field_classes %>
    </div>
    <div>
      <%= f.label :price, "Price", class: label_classes %>
      <%= f.number_field :price, required: true, step: "any", min: 0, class: field_classes %>
    </div>
  </div>

  <div>
    <%= f.label :executed_at, "Executed at", class: label_classes %>
    <%= f.datetime_local_field :executed_at, required: true, class: field_classes %>
  </div>

  <div>
    <%= f.label :fee, "Fee", class: label_classes %>
    <%= f.number_field :fee, step: "any", min: 0, placeholder: "0", class: field_classes %>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :position_side, "Position side", class: label_classes %>
      <%= f.select :position_side,
            options_for_select([["Auto-detect", ""], ["LONG", "LONG"], ["SHORT", "SHORT"]], @trade.position_side),
            {}, class: field_classes %>
    </div>
    <div>
      <%= f.label :leverage, "Leverage", class: label_classes %>
      <%= f.number_field :leverage, step: 1, min: 1, class: field_classes %>
    </div>
  </div>

  <div>
    <%= f.label :realized_pnl, "Realized PnL", class: label_classes %>
    <%= f.number_field :realized_pnl, step: "any", placeholder: "0", class: field_classes %>
  </div>

  <div class="mt-6 flex items-center gap-3">
    <%= f.submit submit_label, class: "rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700 cursor-pointer" %>
    <%= link_to "Cancel", admin_student_trades_path(@student), class: "text-sm text-slate-500 hover:text-slate-800" %>
  </div>
<% end %>
