<%= render PageHeaderComponent.new(title: "#{@student.email} — Trades") do |c| %>
  <% c.with_actions do %>
    <%= link_to "New trade", new_admin_student_trade_path(@student),
          class: "rounded-md bg-indigo-600 px-3 py-2 text-sm font-medium text-white hover:bg-indigo-700" %>
    <%= link_to "← Student", admin_student_path(@student), class: "text-sm text-slate-500 hover:text-slate-800" %>
  <% end %>
<% end %>

<%= render CardComponent.new do %>
  <% if @trades.any? %>
    <%= render DataTableComponent.new(columns: [
      { label: "Symbol",   classes: "text-left" },
      { label: "Side",     classes: "text-left" },
      { label: "Exchange", classes: "text-left" },
      { label: "Date",     classes: "text-left" },
      { label: "Net",      classes: "text-right" },
      { label: "",         classes: "text-right" }
    ]) do |table| %>
      <% @trades.each do |trade| %>
        <% table.with_row do %>
          <td class="whitespace-nowrap px-6 py-4 text-sm font-medium text-slate-900">
            <%= trade.symbol %>
            <% if trade.discarded_at? %>
              <span class="ml-1 rounded bg-red-100 px-1.5 py-0.5 text-xs text-red-600">deleted</span>
            <% end %>
          </td>
          <td class="whitespace-nowrap px-6 py-4 text-sm capitalize text-slate-700"><%= trade.side %></td>
          <td class="whitespace-nowrap px-6 py-4 text-sm text-slate-500"><%= trade.exchange_account.provider_type %></td>
          <td class="whitespace-nowrap px-6 py-4 text-sm text-slate-500"><%= trade.executed_at.strftime("%b %d, %Y") %></td>
          <td class="whitespace-nowrap px-6 py-4 text-right text-sm text-slate-700"><%= number_with_precision(trade.net_amount, precision: 2) %></td>
          <td class="whitespace-nowrap px-6 py-4 text-right text-sm">
            <% unless trade.discarded_at? %>
              <%= link_to "Edit", edit_admin_student_trade_path(@student, trade),
                    class: "mr-3 text-indigo-600 hover:text-indigo-900" %>
              <%= button_to "Delete", admin_student_trade_path(@student, trade),
                    method: :delete,
                    data: { turbo_confirm: "Delete this trade? This cannot be undone." },
                    class: "text-red-600 hover:text-red-900 bg-transparent border-0 cursor-pointer text-sm" %>
            <% end %>
          </td>
        <% end %>
      <% end %>
    <% end %>
    <% if @pagy.last > 1 %>
      <div class="px-6 py-3"><%== @pagy.series_nav %></div>
    <% end %>
  <% else %>
    <p class="px-6 py-4 text-sm text-slate-500">No trades yet.</p>
  <% end %>
<% end %>
