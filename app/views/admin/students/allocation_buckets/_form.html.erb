<% field_classes = "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
<% label_classes = "block text-sm font-medium text-slate-700" %>

<%= form_with model: @bucket, url: url, method: method, class: "space-y-4" do |f| %>
  <% if @bucket.errors.any? %>
    <div class="rounded-md border border-red-200 bg-red-50 p-4">
      <ul class="list-inside list-disc space-y-1 text-sm text-red-700">
        <% @bucket.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
      </ul>
    </div>
  <% end %>
  <div>
    <%= f.label :name, "Name", class: label_classes %>
    <%= f.text_field :name, required: true, class: field_classes %>
  </div>
  <div>
    <%= f.label :color, "Color (hex)", class: label_classes %>
    <%= f.text_field :color, placeholder: "#6366f1", class: field_classes %>
  </div>
  <div>
    <%= f.label :target_pct, "Target % (optional)", class: label_classes %>
    <%= f.number_field :target_pct, step: "0.1", min: 0, max: 100, class: field_classes %>
  </div>
  <div class="mt-6 flex items-center gap-3">
    <%= f.submit submit_label, class: "rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700 cursor-pointer" %>
    <%= link_to "Cancel", admin_student_path(@student), class: "text-sm text-slate-500 hover:text-slate-800" %>
  </div>
<% end %>
