<% field_classes = "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
<% label_classes = "block text-sm font-medium text-slate-700" %>

<%= form_with model: @trade, url: url, method: method, class: "space-y-4" do |f| %>
  <% if @trade.errors.any? %>
    <div class="rounded-md border border-red-200 bg-red-50 p-4">
      <ul class="list-inside list-disc space-y-1 text-sm text-red-700">
        <% @trade.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
      </ul>
    </div>
  <% end %>

  <% if method == :post && @stock_portfolios.any? %>
    <div>
      <%= label_tag :stock_portfolio_id, "Portfolio", class: label_classes %>
      <%= select_tag :stock_portfolio_id,
            options_from_collection_for_select(@stock_portfolios, :id, :name),
            class: field_classes %>
    </div>
  <% end %>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :ticker, "Ticker (e.g. AAPL)", class: label_classes %>
      <%= f.text_field :ticker, required: true, class: field_classes %>
    </div>
    <div>
      <%= f.label :side, "Side", class: label_classes %>
      <%= f.select :side, options_for_select([["Buy","buy"],["Sell","sell"]], @trade.side),
            { prompt: "Select" }, required: true, class: field_classes %>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :shares, "Shares", class: label_classes %>
      <%= f.number_field :shares, required: true, step: "any", min: 0, class: field_classes %>
    </div>
    <div>
      <%= f.label :price_usd, "Price (USD)", class: label_classes %>
      <%= f.number_field :price_usd, required: true, step: "any", min: 0, class: field_classes %>
    </div>
  </div>

  <div>
    <%= f.label :total_value_usd, "Total value (USD)", class: label_classes %>
    <%= f.number_field :total_value_usd, required: true, step: "any", class: field_classes %>
  </div>

  <div>
    <%= f.label :executed_at, "Executed at", class: label_classes %>
    <%= f.datetime_local_field :executed_at, required: true, class: field_classes %>
  </div>

  <%= f.hidden_field :row_signature, value: @trade.row_signature.presence || "admin_#{SecureRandom.hex(8)}" %>

  <div class="mt-6 flex items-center gap-3">
    <%= f.submit submit_label, class: "rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700 cursor-pointer" %>
    <%= link_to "Cancel", admin_student_path(@student), class: "text-sm text-slate-500 hover:text-slate-800" %>
  </div>
<% end %>
