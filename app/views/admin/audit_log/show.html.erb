<%= render PageHeaderComponent.new(title: "Audit Log") %>

<%= render CardComponent.new do %>
  <%= form_with url: admin_audit_log_path, method: :get, class: "flex flex-wrap items-end gap-4 px-6 py-4" do |f| %>
    <div>
      <%= label_tag :student_id, "Student", class: "block text-xs font-medium text-slate-500 mb-1" %>
      <%= select_tag :student_id,
            options_from_collection_for_select(@students, :id, :email, params[:student_id]),
            include_blank: "All students",
            class: "rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-indigo-500" %>
    </div>
    <div>
      <%= label_tag :event, "Event", class: "block text-xs font-medium text-slate-500 mb-1" %>
      <%= select_tag :event,
            options_for_select([["All events",""],["Create","create"],["Update","update"],["Destroy","destroy"]], params[:event]),
            class: "rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-indigo-500" %>
    </div>
    <div>
      <%= label_tag :from_date, "From", class: "block text-xs font-medium text-slate-500 mb-1" %>
      <%= date_field_tag :from_date, params[:from_date], class: "rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= label_tag :to_date, "To", class: "block text-xs font-medium text-slate-500 mb-1" %>
      <%= date_field_tag :to_date, params[:to_date], class: "rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <%= submit_tag "Filter", class: "rounded-md bg-slate-700 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800 cursor-pointer" %>
    <%= link_to "Clear", admin_audit_log_path, class: "text-sm text-slate-500 hover:text-slate-800" %>
  <% end %>
<% end %>

<%= render CardComponent.new do %>
  <% if @versions.any? %>
    <%= render DataTableComponent.new(columns: [
      { label: "When",     classes: "text-left" },
      { label: "Actor",    classes: "text-left" },
      { label: "Event",    classes: "text-left" },
      { label: "Resource", classes: "text-left" },
      { label: "Changes",  classes: "text-left" }
    ]) do |table| %>
      <% @versions.each do |v| %>
        <% actor = v.whodunnit ? (JSON.parse(v.whodunnit) rescue {}) : {} %>
        <% table.with_row do %>
          <td class="whitespace-nowrap px-6 py-4 text-sm text-slate-500">
            <%= v.created_at.strftime("%b %d, %Y %H:%M") %>
          </td>
          <td class="whitespace-nowrap px-6 py-4 text-sm">
            <span class="<%= %w[admin super_admin].include?(actor['role']) ? 'font-medium text-indigo-700' : 'text-slate-700' %>">
              <%= actor['name'] || "Unknown" %>
            </span>
            <span class="ml-1 rounded bg-slate-100 px-1.5 py-0.5 text-xs text-slate-500 capitalize">
              <%= actor['role'] || "?" %>
            </span>
          </td>
          <td class="whitespace-nowrap px-6 py-4 text-sm capitalize">
            <span class="rounded px-2 py-0.5 text-xs font-medium <%= v.event == 'create' ? 'bg-emerald-100 text-emerald-700' : v.event == 'destroy' ? 'bg-red-100 text-red-700' : 'bg-amber-100 text-amber-700' %>">
              <%= v.event %>
            </span>
          </td>
          <td class="whitespace-nowrap px-6 py-4 text-sm text-slate-700">
            <%= v.item_type %> #<%= v.item_id %>
          </td>
          <td class="px-6 py-4 text-sm text-slate-500 max-w-xs truncate">
            <% if v.object_changes.present? %>
              <% changes = (JSON.parse(v.object_changes) rescue {}) %>
              <%= changes.except("updated_at", "created_at").map { |k, (a, b)| "#{k}: #{a.inspect} → #{b.inspect}" }.first(3).join(", ") %>
            <% else %>
              —
            <% end %>
          </td>
        <% end %>
      <% end %>
    <% end %>
    <% if @pagy.last > 1 %>
      <div class="px-6 py-3"><%== @pagy.series_nav %></div>
    <% end %>
  <% else %>
    <p class="px-6 py-4 text-sm text-slate-500">No audit entries match the current filters.</p>
  <% end %>
<% end %>
