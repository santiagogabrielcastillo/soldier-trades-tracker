<div class="max-w-2xl">
  <h1 class="mb-2 text-2xl font-semibold text-slate-900">Settings</h1>
  <p class="mb-6 text-sm text-slate-600">Configure how often your exchange accounts are synced. This applies to all your linked accounts.</p>

  <%= form_with model: current_user, url: settings_path, method: :patch, local: true, class: "space-y-6" do |f| %>
    <%= render ErrorSummaryComponent.new(model: current_user) %>

    <fieldset>
      <legend class="block text-sm font-medium text-slate-900">Sync interval</legend>
      <p class="mb-3 text-sm text-slate-500">How often to fetch new trades from your linked accounts (max 2 syncs per account per day).</p>
      <div class="space-y-3">
        <% User::SYNC_INTERVALS.each do |interval| %>
          <label class="flex cursor-pointer items-start gap-3 rounded-lg border border-slate-200 bg-white p-4 hover:border-slate-300 has-[:checked]:border-slate-800 has-[:checked]:ring-1 has-[:checked]:ring-slate-800">
            <%= f.radio_button :sync_interval, interval, class: "mt-1 h-4 w-4 border-slate-300 text-slate-800 focus:ring-slate-500" %>
            <div>
              <span class="font-medium text-slate-900"><%= interval == "hourly" ? "Hourly" : interval == "daily" ? "Daily" : "Twice daily" %></span>
              <span class="ml-2 text-sm text-slate-500"><%= interval_hint(interval) %></span>
            </div>
          </label>
        <% end %>
      </div>
      <% if current_user.sync_interval.present? %>
        <p class="mt-3 text-sm text-slate-500">
          Current: <strong><%= current_user.sync_interval == "hourly" ? "Hourly" : current_user.sync_interval == "daily" ? "Daily" : "Twice daily (08:00 & 20:00 UTC)" %></strong>.
          <% last_run = current_user.exchange_accounts.maximum(:last_synced_at) %>
          <% if last_run %>
            Last sync across accounts: <%= time_ago_in_words(last_run) %> ago.
          <% else %>
            No sync has run yet; set an interval and wait for the next run, or use "Sync now" on Exchange accounts.
          <% end %>
        </p>
      <% end %>
    </fieldset>

    <%= f.submit "Save settings", class: "rounded-md bg-slate-800 px-4 py-2 text-sm font-medium text-white hover:bg-slate-700 focus:outline-none focus:ring-2 focus:ring-slate-500 focus:ring-offset-2" %>
  <% end %>

  <hr class="border-slate-200">

  <div class="rounded-lg border border-slate-200 bg-white">
    <%# AI Assistant Card %>
    <div class="flex items-center justify-between px-4 py-3 border-b border-slate-100">
      <div class="flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-slate-500" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
        </svg>
        <span class="text-sm font-semibold text-slate-800">AI Assistant</span>
      </div>
      <span class="text-xs text-slate-400">Powered by Gemini</span>
    </div>

    <div class="px-4 py-4 space-y-4">
      <p class="text-sm text-slate-600">
        Connect your free Gemini API key to enable AI-powered portfolio analysis.
        <a href="https://aistudio.google.com/app/apikey" target="_blank" rel="noopener noreferrer" class="text-slate-800 underline underline-offset-2 hover:text-slate-600">Get a free key at aistudio.google.com</a>
      </p>

      <% if current_user.gemini_api_key_configured? %>
        <div data-controller="ai-settings" data-ai-settings-test-url-value="<%= ai_test_saved_key_path %>">
          <div class="flex items-center gap-3 mb-3">
            <span class="flex-1 rounded-md bg-slate-50 border border-slate-200 px-3 py-2 text-sm font-mono text-slate-700"><%= current_user.gemini_api_key_masked %></span>
            <div class="flex items-center gap-1.5 shrink-0">
              <span class="inline-block w-2 h-2 rounded-full bg-emerald-500" aria-hidden="true"></span>
              <span class="text-xs font-medium text-emerald-700">Active</span>
            </div>
          </div>
          <div class="flex items-center gap-2">
            <button type="button"
              data-action="click->ai-settings#testConnection"
              class="px-3 py-1.5 text-sm bg-slate-800 text-white rounded-md hover:bg-slate-700 focus:outline-none focus:ring-2 focus:ring-slate-500 focus:ring-offset-2">
              Test Connection
            </button>
            <%= button_to "Remove", remove_settings_ai_key_path, method: :delete,
              class: "px-3 py-1.5 text-sm text-red-600 hover:text-red-700 hover:bg-red-50 rounded-md focus:outline-none focus:ring-2 focus:ring-red-300 focus:ring-offset-2 transition-colors" %>
          </div>
          <p class="mt-2 text-xs text-slate-400" data-ai-settings-target="result"></p>
        </div>
      <% else %>
        <%= form_with url: settings_ai_key_path, method: :patch do |f| %>
          <div class="flex gap-2">
            <%= f.text_field :api_key,
              placeholder: "AIza...",
              autocomplete: "off",
              class: "flex-1 rounded-md border border-slate-300 px-3 py-2 text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-500 focus:border-transparent" %>
            <%= f.submit "Save",
              class: "px-4 py-2 text-sm bg-slate-800 text-white rounded-md hover:bg-slate-700 focus:outline-none focus:ring-2 focus:ring-slate-500 shrink-0" %>
          </div>
          <p class="mt-1.5 text-xs text-slate-400">Your key is stored encrypted and never shared.</p>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
