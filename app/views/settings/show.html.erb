<div class="mx-auto max-w-lg">
  <h1 class="mb-2 text-2xl font-semibold text-slate-900">Settings</h1>
  <p class="mb-6 text-sm text-slate-600">Configure how often your exchange accounts are synced. This applies to all your linked accounts.</p>

  <%= form_with model: current_user, url: settings_path, method: :patch, local: true, class: "space-y-6" do |f| %>
    <%= render ErrorSummaryComponent.new(model: current_user) %>

    <fieldset>
      <legend class="block text-sm font-medium text-slate-900">Sync interval</legend>
      <p class="mb-3 text-sm text-slate-500">How often to fetch new trades from your linked accounts (max 2 syncs per account per day).</p>
      <div class="space-y-3">
        <% User::SYNC_INTERVALS.each do |interval| %>
          <label class="flex cursor-pointer items-start gap-3 rounded-lg border border-slate-200 bg-white p-4 hover:border-slate-300 has-[:checked]:border-slate-800 has-[:checked]:ring-1 has-[:checked]:ring-slate-800">
            <%= f.radio_button :sync_interval, interval, class: "mt-1 h-4 w-4 border-slate-300 text-slate-800 focus:ring-slate-500" %>
            <div>
              <span class="font-medium text-slate-900"><%= interval == "hourly" ? "Hourly" : interval == "daily" ? "Daily" : "Twice daily" %></span>
              <span class="ml-2 text-sm text-slate-500"><%= interval_hint(interval) %></span>
            </div>
          </label>
        <% end %>
      </div>
      <% if current_user.sync_interval.present? %>
        <p class="mt-3 text-sm text-slate-500">
          Current: <strong><%= current_user.sync_interval == "hourly" ? "Hourly" : current_user.sync_interval == "daily" ? "Daily" : "Twice daily (08:00 & 20:00 UTC)" %></strong>.
          <% last_run = current_user.exchange_accounts.maximum(:last_synced_at) %>
          <% if last_run %>
            Last sync across accounts: <%= time_ago_in_words(last_run) %> ago.
          <% else %>
            No sync has run yet; set an interval and wait for the next run, or use "Sync now" on Exchange accounts.
          <% end %>
        </p>
      <% end %>
    </fieldset>

    <%= f.submit "Save settings", class: "rounded-md bg-slate-800 px-4 py-2 text-sm font-medium text-white hover:bg-slate-700 focus:outline-none focus:ring-2 focus:ring-slate-500 focus:ring-offset-2" %>
  <% end %>

  <hr class="border-slate-200">

  <fieldset>
    <legend class="block text-sm font-medium text-slate-900">AI Assistant</legend>
    <p class="mb-3 text-sm text-slate-500">Connect your Gemini API key to enable AI-powered insights on your portfolio.</p>

    <% if current_user.gemini_api_key_configured? %>
      <div class="rounded-lg border border-slate-200 bg-white p-4">
        <div class="mb-3 flex items-center gap-2">
          <span class="font-mono text-sm text-slate-700"><%= current_user.gemini_api_key_masked %></span>
          <span class="rounded-full bg-emerald-100 px-2 py-0.5 text-xs font-medium text-emerald-700">Configured</span>
        </div>
        <div class="flex flex-wrap items-center gap-3">
          <%= button_to "Remove", remove_settings_ai_key_path, method: :delete,
                class: "rounded-md border border-slate-300 bg-white px-3 py-1.5 text-sm font-medium text-slate-700 hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-slate-500 focus:ring-offset-2" %>
          <button type="button" id="ai-test-btn"
                  class="rounded-md bg-indigo-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2">
            Test Connection
          </button>
          <span id="ai-test-result" class="text-sm"></span>
        </div>
      </div>

      <script>
        document.getElementById('ai-test-btn').addEventListener('click', function() {
          var btn = this;
          var result = document.getElementById('ai-test-result');
          btn.disabled = true;
          btn.textContent = 'Testing...';
          result.textContent = '';
          result.className = 'text-sm';

          fetch('<%= ai_test_saved_key_path %>', {
            method: 'POST',
            headers: {
              'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content,
              'Accept': 'application/json'
            }
          })
          .then(function(res) { return res.json(); })
          .then(function(data) {
            if (data.success) {
              result.textContent = '\u2713 Connection successful';
              result.className = 'text-sm font-medium text-emerald-600';
            } else {
              result.textContent = '\u2717 ' + (data.error || 'Invalid key');
              result.className = 'text-sm font-medium text-red-600';
            }
          })
          .catch(function() {
            result.textContent = '\u2717 Request failed';
            result.className = 'text-sm font-medium text-red-600';
          })
          .finally(function() {
            btn.disabled = false;
            btn.textContent = 'Test Connection';
          });
        });
      </script>
    <% else %>
      <%= form_with url: settings_ai_key_path, method: :patch, local: true do |f| %>
        <div class="rounded-lg border border-slate-200 bg-white p-4">
          <div class="mb-3">
            <%= f.label :api_key, "Gemini API Key", class: "block text-sm font-medium text-slate-700 mb-1" %>
            <%= f.text_field :api_key, placeholder: "AIza...",
                  class: "block w-full rounded-md border border-slate-300 px-3 py-2 text-sm text-slate-900 placeholder-slate-400 focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500" %>
          </div>
          <%= f.submit "Save API Key",
                class: "rounded-md bg-slate-800 px-4 py-2 text-sm font-medium text-white hover:bg-slate-700 focus:outline-none focus:ring-2 focus:ring-slate-500 focus:ring-offset-2" %>
        </div>
      <% end %>
    <% end %>
  </fieldset>
</div>
