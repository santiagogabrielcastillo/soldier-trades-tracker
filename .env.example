# Copy this file to .env for local development.
# Production secrets go in .kamal/secrets — never commit real values.

# Exchange integrations
BINGX_API_URL=https://open-api-vst.bingx.com
FINNHUB_API_KEY=
IOL_USERNAME=
IOL_PASSWORD=

# Production only — generate with: bin/rails db:encryption:init
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=

# Production only — your app's public hostname (e.g. trades.example.com)
APP_HOST=

# Set to "true" only when you need to create new accounts
REGISTRATION_OPEN=true
