{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Rails web server",
      "runtimeExecutable": "bin/rails",
      "runtimeArgs": ["server", "-p", "3000"],
      "port": 3000
    },
    {
      "name": "Tailwind CSS watcher",
      "runtimeExecutable": "bin/rails",
      "runtimeArgs": ["tailwindcss:watch"]
    },
    {
      "name": "Solid Queue worker",
      "runtimeExecutable": "bundle",
      "runtimeArgs": ["exec", "rails", "solid_queue:start"]
    }
  ]
}
